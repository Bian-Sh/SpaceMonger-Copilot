<UserControl x:Class="SpaceMonger.App.Controls.CodeBlockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="500">

    <Border Background="#1A1A1E"
            CornerRadius="10"
            Padding="0"
            BorderBrush="{StaticResource VP.BorderLightBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header bar with language label and Copy button -->
            <Border Grid.Row="0"
                    Background="{StaticResource VP.SurfaceHoverBrush}"
                    CornerRadius="10,10,0,0"
                    Padding="12,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Language, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="{StaticResource VP.TextTertiaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            x:Name="CopyButton"
                            Content="{loc:Loc CopyButton}"
                            Style="{StaticResource VP.Button}"
                            Click="CopyButton_Click"
                            Padding="10,3"
                            FontSize="11"
                            Cursor="Hand"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Code content -->
            <TextBlock Grid.Row="1"
                       Text="{Binding CodeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{StaticResource VP.TextPrimaryBrush}"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Padding="14,10"
                       VerticalAlignment="Top" />
        </Grid>
    </Border>
</UserControl>
