<UserControl x:Class="SpaceMonger.App.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36"
             Background="Transparent">

    <Grid Background="Transparent"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left: App icon + title -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="16,0"
                    IsHitTestVisible="False">
            <TextBlock Text="&#x1F4BE;"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Text="SpaceMonger Next"
                       Foreground="{StaticResource VP.TextPrimaryBrush}"
                       FontFamily="{StaticResource VP.FontFamily}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Right: Window controls -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="MinimizeButton"
                    Content="&#xE921;"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="MinimizeButton_Click"
                    ToolTip="Minimize" />
            <Button x:Name="MaximizeButton"
                    Content="&#xE922;"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="MaximizeButton_Click"
                    ToolTip="Maximize" />
            <Button x:Name="CloseButton"
                    Content="&#xE8BB;"
                    Style="{StaticResource VP.TitleBarCloseButton}"
                    Click="CloseButton_Click"
                    ToolTip="Close" />
        </StackPanel>
    </Grid>
</UserControl>
