<UserControl x:Class="SpaceMonger.App.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36"
             Background="Transparent">

    <Grid Background="Transparent"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left: App icon + title -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="16,0"
                    IsHitTestVisible="False">
            <TextBlock Text="&#xE74E;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="14"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Text="SpaceMonger Next"
                       Foreground="{StaticResource VP.TextPrimaryBrush}"
                       FontFamily="{StaticResource VP.FontFamily}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Right: Settings + Window controls -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="SettingsButton"
                    Content="&#xE713;"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="SettingsButton_Click"
                    ToolTip="Settings" />
            <Button x:Name="CollapseChatButton"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="CollapseChatButton_Click"
                    ToolTip="Toggle chat panel">
                <Button.Content>
                    <Grid Width="16" Height="12">
                        <!-- Chat open: rectangle with divider slightly right (right panel = chat) -->
                        <Grid x:Name="PanelOpenIcon">
                            <Border BorderBrush="{StaticResource VP.TextSecondaryBrush}"
                                    BorderThickness="1" CornerRadius="2" />
                            <Line X1="9.5" Y1="0" X2="9.5" Y2="12"
                                  Stroke="{StaticResource VP.TextSecondaryBrush}" StrokeThickness="1" />
                        </Grid>
                        <!-- Chat collapsed: rectangle with divider slightly left (left panel = chat) -->
                        <Grid x:Name="PanelClosedIcon" Visibility="Collapsed">
                            <Border BorderBrush="{StaticResource VP.TextSecondaryBrush}"
                                    BorderThickness="1" CornerRadius="2" />
                            <Line X1="6.5" Y1="0" X2="6.5" Y2="12"
                                  Stroke="{StaticResource VP.TextSecondaryBrush}" StrokeThickness="1" />
                        </Grid>
                    </Grid>
                </Button.Content>
            </Button>
            <Button x:Name="MinimizeButton"
                    Content="&#xE921;"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="MinimizeButton_Click"
                    ToolTip="Minimize" />
            <Button x:Name="MaximizeButton"
                    Content="&#xE922;"
                    Style="{StaticResource VP.TitleBarButton}"
                    Click="MaximizeButton_Click"
                    ToolTip="Maximize" />
            <Button x:Name="CloseButton"
                    Content="&#xE8BB;"
                    Style="{StaticResource VP.TitleBarCloseButton}"
                    Click="CloseButton_Click"
                    ToolTip="Close" />
        </StackPanel>
    </Grid>
</UserControl>
