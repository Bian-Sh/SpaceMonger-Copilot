<UserControl x:Class="SpaceMonger.App.Controls.AppModalHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             Focusable="True"
             FontFamily="{StaticResource VP.FontFamily}">
    <Grid Background="#60484853">
        <Border x:Name="ModalCard"
                Style="{StaticResource VP.GlassPanelLarge}"
                Background="{StaticResource VP.BackgroundAltBrush}"
                BorderBrush="{StaticResource VP.BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="0"
                MaxWidth="620"
                MaxHeight="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.26"
                                  BlurRadius="26"
                                  ShadowDepth="6"
                                  Direction="270" />
            </Border.Effect>
            <ContentPresenter x:Name="ModalContentPresenter" />
        </Border>
    </Grid>
</UserControl>

