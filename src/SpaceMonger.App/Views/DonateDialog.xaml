<Window x:Class="SpaceMonger.App.Views.DonateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        Title="{loc:Loc DonateDialogTitle}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource VP.FontFamily}">

    <Window.Resources>
        <Style x:Key="DonateCloseButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource VP.SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VP.BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource VP.DangerBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource VP.DangerPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource VP.OverlayBrush}">
        <Border Background="{StaticResource VP.BackgroundAltBrush}"
                BorderBrush="{StaticResource VP.BorderLightBrush}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.26"
                                  BlurRadius="26" ShadowDepth="6" Direction="270" />
            </Border.Effect>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏：title居中，关闭按钮独立定位右上角 -->
            <Grid Grid.Row="0">
                <TextBlock FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource VP.TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0">
                    <Run Text="☕ " /><Run Text="{loc:Loc DonateDialogTitle}" />
                </TextBlock>
                <Button Style="{StaticResource DonateCloseButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"
                        Click="CloseButton_Click">
                    <TextBlock Text="&#x2715;" FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <!-- 二维码：StackPanel居中，margin=6，左中右间隙≈均等 -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,10,0,8">
                <StackPanel Margin="6,0">
                    <Image Source="pack://application:,,,/Assets/QR_Alipay.jpg"
                           Width="220" Height="260"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,6" />
                    <TextBlock Text="{loc:Loc DonateAlipayLabel}"
                               FontSize="13"
                               Foreground="{StaticResource VP.TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="6,0">
                    <Image Source="pack://application:,,,/Assets/QR_WeChat.jpg"
                           Width="220" Height="260
"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,6" />
                    <TextBlock Text="{loc:Loc DonateWeChatLabel}"
                               FontSize="13"
                               Foreground="{StaticResource VP.TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- 底部感谢 -->
            <TextBlock Grid.Row="2"
                       FontSize="16
                       "
                       Foreground="{StaticResource VP.TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14">
                <Run Text="{loc:Loc DonateThankYou}" /><Run Text="❤" Foreground="#E2231A" />
            </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
