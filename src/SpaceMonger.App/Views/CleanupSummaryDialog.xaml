<Window x:Class="SpaceMonger.App.Views.CleanupSummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc CleanupSummaryTitle}"
        Width="460" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        FontFamily="{StaticResource VP.FontFamily}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource VP.GlassPanelLarge}"
            Background="{StaticResource VP.BackgroundAltBrush}"
            Padding="24"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Success summary -->
            <TextBlock x:Name="SuccessSummary"
                       Grid.Row="0"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VP.SuccessBrush}"
                       Margin="0,0,0,12" />

            <!-- Already removed -->
            <TextBlock x:Name="AlreadyRemovedText"
                       Grid.Row="1"
                       Foreground="{StaticResource VP.TextSecondaryBrush}"
                       FontSize="13"
                       Margin="0,0,0,8" />

            <!-- Skipped items -->
            <Border x:Name="SkippedGroup"
                    Grid.Row="2"
                    Background="{StaticResource VP.SurfaceHoverBrush}"
                    BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SkippedGroupHeader"
                               Grid.Row="0"
                               Foreground="{StaticResource VP.TextSecondaryBrush}"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="0,0,0,6" />
                    <ListView x:Name="SkippedItemsList"
                              Grid.Row="1"
                              Style="{StaticResource VP.ListView}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{loc:Loc PathColumn}" Width="240"
                                                DisplayMemberBinding="{Binding Path}" />
                                <GridViewColumn Header="{loc:Loc ReasonColumn}" Width="160"
                                                DisplayMemberBinding="{Binding Reason}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- Total space recovered -->
            <TextBlock x:Name="TotalRecovered"
                       Grid.Row="3"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VP.TextPrimaryBrush}"
                       FontSize="13"
                       Margin="0,4,0,8" />

            <!-- OK Button -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="{loc:Loc OkButton}"
                        Style="{StaticResource VP.AccentButton}"
                        Width="84" Height="32"
                        IsDefault="True"
                        Click="OkButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
