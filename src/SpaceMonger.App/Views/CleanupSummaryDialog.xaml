<Window x:Class="SpaceMonger.App.Views.CleanupSummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc CleanupSummaryTitle}"
        Width="450" Height="350"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Success summary -->
        <TextBlock x:Name="SuccessSummary"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="Green"
                   Margin="0,0,0,12" />

        <!-- Row 1: Already removed -->
        <TextBlock x:Name="AlreadyRemovedText"
                   Grid.Row="1"
                   Foreground="#555555"
                   Margin="0,0,0,8" />

        <!-- Row 2: Skipped items -->
        <GroupBox x:Name="SkippedGroup"
                  Grid.Row="2"
                  Header="{loc:Loc SkippedItemsHeader}"
                  Margin="0,0,0,8">
            <ListView x:Name="SkippedItemsList"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{loc:Loc PathColumn}" Width="240"
                                        DisplayMemberBinding="{Binding Path}" />
                        <GridViewColumn Header="{loc:Loc ReasonColumn}" Width="160"
                                        DisplayMemberBinding="{Binding Reason}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Row 3: Total space recovered -->
        <TextBlock x:Name="TotalRecovered"
                   Grid.Row="3"
                   FontWeight="SemiBold"
                   Margin="0,4,0,8" />

        <!-- Row 4: OK Button -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="{loc:Loc OkButton}"
                    Width="80"
                    Height="28"
                    IsDefault="True"
                    Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>
