<Window x:Class="SpaceMonger.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
        Title="{loc:Loc SettingsTitle}"
        Width="450" Height="540"
        MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{loc:Loc SaveButton}"
                    Width="80"
                    Height="28"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button Content="{loc:Loc CancelButton}"
                    Width="80"
                    Height="28"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="{loc:Loc AnthropicApiKeyHeader}" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"
                                 Padding="4"
                                 ToolTip="{loc:Loc ApiKeyToolTip}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Loc ValidateButton}"
                                    Padding="12,4"
                                    Margin="0,0,8,0"
                                    Command="{Binding ValidateCommand}" />
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="" />
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ValidationState}" Value="{x:Static vm:ValidationState.Validating}">
                                                <Setter Property="Text" Value="Validating..." />
                                                <Setter Property="Foreground" Value="Gray" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ValidationState}" Value="{x:Static vm:ValidationState.Valid}">
                                                <Setter Property="Text" Value="&#x2714; Valid" />
                                                <Setter Property="Foreground" Value="Green" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ValidationState}" Value="{x:Static vm:ValidationState.Invalid}">
                                                <Setter Property="Text" Value="&#x2718; Invalid" />
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="Red"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding ValidationMessage, TargetNullValue=Collapsed, FallbackValue=Visible}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc AnthropicBaseUrlHeader}" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBox Text="{Binding AnthropicBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,6"
                                 Padding="4"
                                 ToolTip="{loc:Loc AnthropicBaseUrlToolTip}" />
                        <TextBlock Text="{loc:Loc AnthropicBaseUrlHint}"
                                   Foreground="#666666"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc DefaultDeletionModeHeader}" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <ComboBox SelectedItem="{Binding SelectedDeletionMode}"
                                  Padding="4">
                            <ComboBox.Items>
                                <enums:DeletionMode>MoveToRecycleBin</enums:DeletionMode>
                                <enums:DeletionMode>PermanentDelete</enums:DeletionMode>
                            </ComboBox.Items>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Unknown" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:DeletionMode.MoveToRecycleBin}">
                                                        <Setter Property="Text" Value="Move to Recycle Bin" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:DeletionMode.PermanentDelete}">
                                                        <Setter Property="Text" Value="Permanently Delete" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc DataPrivacyHeader}" Margin="0,0,0,12">
                    <TextBlock Margin="8"
                               TextWrapping="Wrap"
                               Foreground="#555555"
                               Text="{loc:Loc DataPrivacyText}" />
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
