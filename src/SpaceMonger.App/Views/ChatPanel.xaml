<UserControl x:Class="SpaceMonger.App.Views.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChatViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="380">

    <DockPanel>

        <!-- 1. API Key Warning (top, conditional) -->
        <Border DockPanel.Dock="Top"
                Background="#FFF3E0"
                BorderBrush="#FFB74D"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsApiKeyConfigured}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{loc:Loc ChatConfigureApiKey}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#E65100"
                           FontSize="12"
                           Margin="0,0,0,6" />
                <Button x:Name="OpenSettingsButton"
                        Content="{loc:Loc OpenSettingsButton}"
                        HorizontalAlignment="Center"
                        Padding="12,4"
                        FontSize="11"
                        Click="OpenSettingsButton_Click" />
            </StackPanel>
        </Border>

        <!-- 4. Input Area (bottom) -->
        <Border DockPanel.Dock="Bottom"
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{loc:Loc SendButton}"
                        Padding="12,6"
                        Margin="6,0,0,0"
                        VerticalAlignment="Stretch"
                        Command="{Binding SendCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSending}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBox x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         Padding="6,4"
                         KeyDown="InputTextBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSending}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- 3. Context Indicator (above input, conditional) -->
        <Border DockPanel.Dock="Bottom"
                Background="#E8F5E9"
                BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LinkedItemPath, TargetNullValue=''}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="X"
                        FontSize="10"
                        Padding="4,1"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Click="ClearContextButton_Click"
                        ToolTip="{loc:Loc ClearContextToolTip}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#2E7D32"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="{loc:Loc ChatContextLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding LinkedItemPath, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- 2. Message List (scrollable, fills remaining space) -->
        <ScrollViewer x:Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MessagesItemsControl"
                          ItemsSource="{Binding Messages}"
                          Padding="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="10,8" CornerRadius="6" MaxWidth="320">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- Default: Assistant style (left-aligned, gray) -->
                                    <Setter Property="Background" Value="#F5F5F5" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Style.Triggers>
                                        <!-- User messages: right-aligned, blue-ish -->
                                        <DataTrigger Binding="{Binding Sender}" Value="{x:Static enums:ChatSender.User}">
                                            <Setter Property="Background" Value="#E3F2FD" />
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                        </DataTrigger>
                                        <!-- Error messages keep left alignment but get a light red background -->
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE" />
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <!-- Thinking indicator: shown while streaming with no text yet -->
                                <TextBlock Text="{loc:Loc ThinkingText}"
                                           FontStyle="Italic"
                                           Foreground="#9E9E9E"
                                           FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                        <Condition Binding="{Binding Text}" Value="" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Streaming cursor: append a blinking block cursor while streaming -->
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#212121" />
                                            <Setter Property="FontFamily" Value="Segoe UI" />
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <!-- Hide when streaming with no text yet (thinking indicator shown instead) -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                        <Condition Binding="{Binding Text}" Value="" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </MultiDataTrigger>
                                                <!-- Error text in red -->
                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                    <Setter Property="Foreground" Value="#D32F2F" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Text, Mode=OneWay}" /><Run Text=" &#x2588;">
                                        <Run.Style>
                                            <Style TargetType="Run">
                                                <Setter Property="Foreground" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                        <Setter Property="Foreground" Value="#9E9E9E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Run.Style>
                                    </Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
