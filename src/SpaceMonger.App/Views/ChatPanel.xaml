<UserControl x:Class="SpaceMonger.App.Views.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChatViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="380"
             FontFamily="{StaticResource VP.FontFamily}">

    <UserControl.Resources>
        <converters:MarkdownToFlowDocumentConverter x:Key="MarkdownConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:SubtractConverter x:Key="SubtractConverter" Subtrahend="50" />
    </UserControl.Resources>

    <Border Style="{StaticResource VP.GlassPanelLarge}" Margin="0" Padding="0">
        <DockPanel>

            <!-- 1. API Key Warning (top, conditional) -->
            <Border DockPanel.Dock="Top"
                    Background="#1AFF9500"
                    BorderBrush="#33FF9500"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    Padding="14,10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsApiKeyConfigured}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Loc ChatConfigureApiKey}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="#FF9500"
                               FontSize="12"
                               Margin="0,0,0,8" />
                    <Button x:Name="OpenSettingsButton"
                            Content="{loc:Loc OpenSettingsButton}"
                            Style="{StaticResource VP.Button}"
                            HorizontalAlignment="Center"
                            Padding="14,6"
                            FontSize="11"
                            Click="OpenSettingsButton_Click" />
                </StackPanel>
            </Border>

            <!-- 4. Input Area (bottom) -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource VP.SurfaceBrush}"
                    BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="10">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="{loc:Loc SendButton}"
                            Padding="14,8"
                            Margin="8,0,0,0"
                            VerticalAlignment="Stretch"
                            Command="{Binding SendCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource VP.AccentButton}">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSending}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBox x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="False"
                             VerticalContentAlignment="Center"
                             KeyDown="InputTextBox_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource VP.TextBox}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSending}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- 3. Context Indicator (above input, conditional) -->
            <Border DockPanel.Dock="Bottom"
                    Background="#1A30D158"
                    BorderBrush="#3330D158"
                    BorderThickness="0,1,0,0"
                    Padding="10,5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LinkedItemPath, TargetNullValue=''}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Padding="4,2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Click="ClearContextButton_Click"
                            ToolTip="{loc:Loc ClearContextToolTip}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource VP.TextSecondaryBrush}"
                            Cursor="Hand" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource VP.SuccessBrush}"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="{loc:Loc ChatContextLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding LinkedItemPath, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- 2. Message List (scrollable, fills remaining space) -->
            <Grid>
                <Border Padding="20"
                        Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMessages}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="260">
                        <TextBlock Text="&#x1F4AC;"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{loc:Loc ChatEmptyTitle}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource VP.TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{loc:Loc ChatEmptyDescription}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="MessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="MessagesItemsControl"
                                  ItemsSource="{Binding Messages}"
                                  Padding="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Container for bubble -->
                                <Border Margin="0,4"
                                        MaxWidth="{Binding ActualWidth, ElementName=MessagesScrollViewer, Converter={StaticResource SubtractConverter}}"
                                        MouseEnter="BubbleBorder_MouseEnter"
                                        MouseLeave="BubbleBorder_MouseLeave">
                                    
                                    <!-- Message bubble -->
                                    <Border Padding="12,9"
                                            CornerRadius="18"
                                            x:Name="BubbleBorder">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource VP.SurfaceHoverBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Sender}" Value="{x:Static enums:ChatSender.User}">
                                                        <Setter Property="Background" Value="#CC0A84FF" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                                        <Setter Property="Background" Value="#33FF453A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Content -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <!-- Thinking section (collapsible) -->
                                                <Border Background="#1AFF9500"
                                                        CornerRadius="8"
                                                        Padding="8,6"
                                                        Margin="0,0,0,4"
                                                        Cursor="Hand"
                                                        Visibility="{Binding HasThinking, Converter={StaticResource BoolToVis}}"
                                                        MouseLeftButtonDown="ThinkingBorder_MouseLeftButtonDown">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE945;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="12"
                                                                       Foreground="#FF9500"
                                                                       Margin="0,0,6,0"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="{loc:Loc ThinkingLabel}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       Foreground="#FF9500"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="&#xE70D;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Foreground="#FF9500"
                                                                       Margin="6,0,0,0"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsThinkingExpanded}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="&#xE70E;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Foreground="#FF9500"
                                                                       Margin="6,0,0,0"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsThinkingExpanded}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Thinking, Mode=OneWay}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   Foreground="#CCFF9500"
                                                                   Margin="0,4,0,0"
                                                                   MaxHeight="200">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsThinkingExpanded}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Thinking indicator -->
                                                <TextBlock Text="{loc:Loc ThinkingText}"
                                                           FontStyle="Italic"
                                                           Foreground="{StaticResource VP.TextTertiaryBrush}"
                                                           FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                                        <Condition Binding="{Binding Text}" Value="" />
                                                                        <Condition Binding="{Binding HasThinking}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Message text with Markdown rendering -->
                                                <FlowDocumentScrollViewer Document="{Binding Text, Converter={StaticResource MarkdownConverter}}"
                                                                          VerticalScrollBarVisibility="Disabled"
                                                                          HorizontalScrollBarVisibility="Disabled"
                                                                          FontSize="13"
                                                                          Foreground="{StaticResource VP.TextPrimaryBrush}"
                                                                          Background="Transparent"
                                                                          IsSelectionEnabled="True"
                                                                          IsToolBarVisible="False"
                                                                          Zoom="100"
                                                                          PreviewMouseWheel="FlowDocumentScrollViewer_PreviewMouseWheel">
                                                    <FlowDocumentScrollViewer.Style>
                                                        <Style TargetType="FlowDocumentScrollViewer">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                                        <Condition Binding="{Binding Text}" Value="" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource VP.DangerBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </FlowDocumentScrollViewer.Style>
                                                </FlowDocumentScrollViewer>

                                                <!-- Streaming cursor -->
                                                <TextBlock Text=" &#x2588;"
                                                           FontSize="13"
                                                           Foreground="{StaticResource VP.TextTertiaryBrush}"
                                                           Margin="0,-4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                                        <Condition Binding="{Binding Text}" Value="" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Copy button for AI messages (bottom-left) -->
                                            <Border x:Name="AiCopyButtonBorder"
                                                    Grid.Row="1" Grid.Column="0"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,4,0,0"
                                                    Cursor="Hand"
                                                    Opacity="0"
                                                    Background="Transparent"
                                                    MouseLeftButtonDown="CopyButton_MouseLeftButtonDown"
                                                    MouseEnter="CopyButton_MouseEnter"
                                                    MouseLeave="CopyButton_MouseLeave"
                                                    ToolTip="{loc:Loc CopyMessageToolTip}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Sender}" Value="{x:Static enums:ChatSender.Assistant}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasText}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Canvas Width="14" Height="14">
                                                    <Path x:Name="AiCopyIcon"
                                                          Data="M6.2513 6.24935V2.91602H17.0846V13.7493H13.7513M13.7513 6.24935V17.0827H2.91797V6.24935H13.7513Z"
                                                          Stroke="White"
                                                          StrokeThickness="1.5"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Opacity="0.6" />
                                                </Canvas>
                                            </Border>

                                            <!-- Copy button for User messages (bottom-right) -->
                                            <Border x:Name="UserCopyButtonBorder"
                                                    Grid.Row="1" Grid.Column="0"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,4,0,0"
                                                    Cursor="Hand"
                                                    Opacity="0"
                                                    Background="Transparent"
                                                    MouseLeftButtonDown="CopyButton_MouseLeftButtonDown"
                                                    MouseEnter="CopyButton_MouseEnter"
                                                    MouseLeave="CopyButton_MouseLeave"
                                                    ToolTip="{loc:Loc CopyMessageToolTip}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Sender}" Value="{x:Static enums:ChatSender.User}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasText}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Canvas Width="14" Height="14">
                                                    <Path x:Name="UserCopyIcon"
                                                          Data="M6.2513 6.24935V2.91602H17.0846V13.7493H13.7513M13.7513 6.24935V17.0827H2.91797V6.24935H13.7513Z"
                                                          Stroke="White"
                                                          StrokeThickness="1.5"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Opacity="0.6" />
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </DockPanel>
    </Border>
</UserControl>

