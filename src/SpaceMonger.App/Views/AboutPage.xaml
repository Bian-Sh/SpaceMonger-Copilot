<UserControl x:Class="SpaceMonger.App.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             d:DataContext="{d:DesignInstance Type=vm:UpdateViewModel, IsDesignTimeCreatable=False}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             FontFamily="{DynamicResource VP.FontFamily}">

    <UserControl.Resources>
        <converters:MarkdownToFlowDocumentConverter x:Key="MarkdownConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource VP.SurfaceBrush}"
            BorderBrush="{DynamicResource VP.BorderLightBrush}"
            BorderThickness="0.5,0,0.5,0.5"
            CornerRadius="0,0,10,10">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              BlurRadius="12"
                              ShadowDepth="2"
                              Opacity="0.3"
                              Direction="270" />
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20">
        <StackPanel MaxWidth="560" HorizontalAlignment="Center">

            <!-- 标题行：标题居中，投喂入口靠右，互不影响 -->
            <Grid HorizontalAlignment="Stretch" Margin="0,0,0,0">
                <TextBlock Text="SpaceMonger Copilot"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource VP.TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom" />
                <TextBlock x:Name="DonateLink"
                           FontSize="12"
                           Cursor="Hand"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,4"
                           MouseLeftButtonDown="DonateLink_Click">
                    <Run Text="☕ " Foreground="{DynamicResource VP.AccentBrush}" />
                    <Run Text="{loc:Loc BuyMeCoffee}" Foreground="{DynamicResource VP.AccentBrush}" />
                </TextBlock>
            </Grid>
            <TextBlock Margin="0,6,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource VP.TextSecondaryBrush}"
                       FontSize="14">
                <Run Text="{loc:Loc VersionLabel}" />
                <Run Text="{Binding CurrentVersion}" />
            </TextBlock>

            <!-- 应用介绍 -->
            <TextBlock Margin="0,20,0,0"
                       Text="{loc:Loc AboutDescription}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource VP.TextSecondaryBrush}"
                       FontSize="13.5"
                       LineHeight="22"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <!-- GitHub 链接 -->
            <TextBlock Margin="0,16,0,0"
                       HorizontalAlignment="Center"
                       FontSize="13">
                <Run Text="{loc:Loc GithubLabel}" Foreground="{DynamicResource VP.TextSecondaryBrush}" />
                <Run Text=": " Foreground="{DynamicResource VP.TextSecondaryBrush}" />
                <Hyperlink NavigateUri="https://github.com/Bian-Sh/SpaceMonger-Copilot"
                           Foreground="{DynamicResource VP.AccentBrush}"
                           TextDecorations="None"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="github.com/Bian-Sh/SpaceMonger-Copilot" />
                </Hyperlink>
            </TextBlock>

            <!-- 分隔线 -->
            <Rectangle Height="1" Margin="0,24,0,0"
                       Fill="{DynamicResource VP.BorderSubtleBrush}" />

            <!-- ═══ 更新状态区域 ═══ -->

            <!-- 状态 A: 无更新 -->
            <Border x:Name="UpToDatePanel"
                    Margin="0,20,0,0"
                    Background="{DynamicResource VP.SurfaceBrush}"
                    BorderBrush="{DynamicResource VP.BorderLightBrush}"
                    BorderThickness="0.5"
                    CornerRadius="12"
                    Padding="16"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Border Width="16"
                            Height="16"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center"
                            BorderBrush="{DynamicResource VP.SuccessBrush}"
                            BorderThickness="1.5"
                            CornerRadius="3">
                        <TextBlock Text="&#x2713;"
                                   Foreground="{DynamicResource VP.SuccessBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-1,0,0" />
                    </Border>
                    <TextBlock Text="{loc:Loc UpToDateStatus}"
                               Foreground="{DynamicResource VP.SuccessBrush}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- 状态 B: 有更新 -->
            <Border x:Name="UpdateAvailablePanel"
                    Margin="0,20,0,0"
                    Background="{DynamicResource VP.SurfaceBrush}"
                    BorderBrush="{DynamicResource VP.BorderLightBrush}"
                    BorderThickness="0.5"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- 更新标题 -->
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource VP.TextPrimaryBrush}">
                        <Run Text="🆕 " />
                        <Run Text="{loc:Loc UpdateAvailableTitle}"
                             x:Name="UpdateTitleRun" />
                    </TextBlock>
                    <TextBlock x:Name="UpdateTitleDetail"
                               Margin="0,2,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource VP.SuccessBrush}" />

                    <!-- 更新日志 -->
                    <TextBlock Margin="0,16,0,6"
                               Text="{loc:Loc ReleaseNotesHeader}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource VP.TextPrimaryBrush}" />
                    <Border Background="#1A1B26"
                            CornerRadius="8"
                            Padding="12,8"
                            MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <FlowDocumentReader Document="{Binding ReleaseNotes, Converter={StaticResource MarkdownConverter}}"
                                                IsFindEnabled="False"
                                                IsPrintEnabled="False"
                                                Zoom="100"
                                                MaxZoom="100"
                                                MinZoom="100"
                                                Background="Transparent" />
                        </ScrollViewer>
                    </Border>

                    <!-- 下载按钮 -->
                    <Button x:Name="DownloadButton"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Stretch"
                            Style="{DynamicResource VP.AccentButton}"
                            Command="{Binding DownloadCommand}"
                            Height="40"
                            FontSize="14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc DownloadUpdateButton}"
                                       x:Name="DownloadButtonLabel"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 状态 C: 下载中 -->
            <Border x:Name="DownloadingPanel"
                    Margin="0,20,0,0"
                    Background="{DynamicResource VP.SurfaceBrush}"
                    BorderBrush="{DynamicResource VP.BorderLightBrush}"
                    BorderThickness="0.5"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource VP.TextPrimaryBrush}">
                        <Run Text="{loc:Loc DownloadingStatus}"
                             x:Name="DownloadingStatusRun" />
                    </TextBlock>

                    <!-- 进度条 -->
                    <Border Margin="0,12,0,0"
                            Height="8"
                            CornerRadius="4"
                            Background="{DynamicResource VP.BackgroundAltBrush}">
                        <Border x:Name="ProgressBarFill"
                                HorizontalAlignment="Left"
                                CornerRadius="4"
                                Background="{DynamicResource VP.AccentBrush}"
                                Width="0" />
                    </Border>

                    <!-- 百分比 -->
                    <TextBlock x:Name="ProgressText"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource VP.TextSecondaryBrush}"
                               HorizontalAlignment="Center" />

                    <!-- 取消按钮 -->
                    <Button x:Name="CancelButton"
                            Margin="0,12,0,0"
                            Style="{DynamicResource VP.Button}"
                            Command="{Binding CancelDownloadCommand}"
                            HorizontalAlignment="Center"
                            Padding="20,6"
                            Content="{loc:Loc CancelButton}" />
                </StackPanel>
            </Border>

            <!-- 状态 D: 下载完成 -->
            <Border x:Name="DownloadCompletePanel"
                    Margin="0,20,0,0"
                    Background="{DynamicResource VP.SurfaceBrush}"
                    BorderBrush="{DynamicResource VP.BorderLightBrush}"
                    BorderThickness="0.5"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="DownloadCompleteStatus"
                               FontSize="14"
                               Foreground="{DynamicResource VP.SuccessBrush}"
                               HorizontalAlignment="Center" />

                    <StackPanel Margin="0,16,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="InstallButton"
                                Style="{DynamicResource VP.AccentButton}"
                                Command="{Binding InstallCommand}"
                                Padding="24,8"
                                FontSize="14"
                                Content="{loc:Loc InstallButton}" />
                        <Button x:Name="ReDownloadButton"
                                Margin="10,0,0,0"
                                Style="{DynamicResource VP.Button}"
                                Command="{Binding ReDownloadCommand}"
                                Padding="16,8"
                                FontSize="13"
                                Content="{loc:Loc ReDownloadButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 底部留白 -->
            <Rectangle Height="20" />
        </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
