<Window x:Class="SpaceMonger.App.Views.CleanupConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Confirm Cleanup"
        Width="400" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Warning -->
        <TextBlock Grid.Row="0"
                   Text="&#x26A0; Are you sure you want to proceed?"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Row 1: Summary info -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock x:Name="ItemCount"
                       Margin="0,0,0,4" />
            <TextBlock x:Name="SpaceToFree"
                       Margin="0,0,0,4" />
        </StackPanel>

        <!-- Row 2: Deletion mode selection -->
        <GroupBox Grid.Row="2" Header="Deletion Mode" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <RadioButton x:Name="RecycleBinRadio"
                             Content="Move to Recycle Bin"
                             IsChecked="True"
                             Margin="0,0,0,8"
                             Checked="DeletionModeRadio_Checked" />
                <RadioButton x:Name="PermanentDeleteRadio"
                             Content="Permanently Delete"
                             Margin="0,0,0,4"
                             Checked="DeletionModeRadio_Checked" />
                <TextBlock x:Name="PermanentDeleteWarning"
                           Text="Warning: Files cannot be recovered!"
                           Foreground="Red"
                           FontWeight="SemiBold"
                           Margin="20,0,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </GroupBox>

        <!-- Row 3: Spacer -->

        <!-- Row 4: Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Confirm"
                    Width="80"
                    Height="28"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="ConfirmButton_Click" />
            <Button Content="Cancel"
                    Width="80"
                    Height="28"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
