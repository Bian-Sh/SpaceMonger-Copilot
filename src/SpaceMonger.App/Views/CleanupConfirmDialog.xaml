<Window x:Class="SpaceMonger.App.Views.CleanupConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc ConfirmCleanupTitle}"
        Width="420" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        FontFamily="{StaticResource VP.FontFamily}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource VP.GlassPanelLarge}"
            Background="{StaticResource VP.BackgroundAltBrush}"
            Padding="24"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Warning -->
            <TextBlock Grid.Row="0"
                       Text="{loc:Loc ConfirmCleanupPrompt}"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VP.TextPrimaryBrush}"
                       Margin="0,0,0,14" />

            <!-- Summary info -->
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock x:Name="ItemCount"
                           Foreground="{StaticResource VP.TextSecondaryBrush}"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="SpaceToFree"
                           Foreground="{StaticResource VP.TextSecondaryBrush}"
                           FontSize="13"
                           Margin="0,0,0,4" />
            </StackPanel>

            <!-- Deletion mode -->
            <Border Grid.Row="2"
                    Background="{StaticResource VP.SurfaceHoverBrush}"
                    BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{loc:Loc DeletionModeHeader}"
                               Foreground="{StaticResource VP.TextSecondaryBrush}"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="0,0,0,8" />
                    <RadioButton x:Name="RecycleBinRadio"
                                 Style="{StaticResource VP.CheckBox}"
                                 Content="{loc:Loc MoveToRecycleBinOption}"
                                 IsChecked="True"
                                 Margin="0,0,0,8"
                                 Checked="DeletionModeRadio_Checked" />
                    <RadioButton x:Name="PermanentDeleteRadio"
                                 Style="{StaticResource VP.CheckBox}"
                                 Content="{loc:Loc PermanentlyDeleteOption}"
                                 Margin="0,0,0,4"
                                 Checked="DeletionModeRadio_Checked" />
                    <TextBlock x:Name="PermanentDeleteWarning"
                               Text="{loc:Loc PermanentDeleteWarning}"
                               Foreground="{StaticResource VP.DangerBrush}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="20,4,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="{loc:Loc CancelButton}"
                        Style="{StaticResource VP.Button}"
                        Width="84" Height="32"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelButton_Click" />
                <Button Content="{loc:Loc ConfirmButton}"
                        Style="{StaticResource VP.DangerButton}"
                        Width="84" Height="32"
                        IsDefault="True"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
