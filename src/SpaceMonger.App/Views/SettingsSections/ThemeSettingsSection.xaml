<UserControl x:Class="SpaceMonger.App.Views.SettingsSections.ThemeSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:theme="clr-namespace:SpaceMonger.Core.Models.Theme;assembly=SpaceMonger.Core"
             xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
             FontFamily="{DynamicResource VP.FontFamily}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SettingsSharedResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock x:Name="ThemeSectionAnchor" Text="{loc:Loc ThemeSectionLabel}"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource VP.TextSecondaryBrush}"
                   Margin="0,16,0,10" />

        <Border x:Name="ThemeSection" Background="{DynamicResource VP.SettingsCardBrush}"
                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <!-- Theme Color Picker + Presets inline -->
                <Grid Margin="14,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{loc:Loc ThemeAccentColorLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeAccentColorHint}"
                               Margin="0,0,0,8" />

                    <!-- Presets row -->
                    <ItemsControl Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{x:Static vm:SettingsViewModel.AvailableThemePresets}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type theme:ThemeProfile}">
                                <Border Style="{StaticResource ThemePresetCardStyle}"
                                        MouseLeftButtonDown="ThemePreset_Click"
                                        Tag="{Binding}"
                                        Width="Auto" Margin="0,0,6,0" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="14" Height="14" Margin="0,0,6,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource HexColorConverter}}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource VP.TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Color Picker -->
                    <controls:ColorPickerControl x:Name="ThemeColorPicker"
                        Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        SelectedColor="{Binding ThemeBackgroundColor, Mode=TwoWay}" />
                </Grid>

                <!-- Glass / Frosted Glass Toggle -->
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ThemeGlassLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeGlassHint}" />
                    <CheckBox Grid.Column="1"
                              Style="{DynamicResource VP.CheckBox}"
                              IsChecked="{Binding GlassEnabled}"
                              Content="{loc:Loc ThemeGlassOption}" />
                </Grid>

                <!-- Glass Backdrop Type -->
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ThemeBackdropTypeLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeBackdropTypeHint}" />
                    <ComboBox Grid.Column="1"
                              Style="{DynamicResource VP.ComboBox}"
                              SelectedIndex="{Binding GlassBackdropType, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.Items>
                            <TextBlock Text="{loc:Loc ThemeBackdropNone}" />
                            <TextBlock Text="Mica" />
                            <TextBlock Text="Acrylic" />
                            <TextBlock Text="Tabbed" />
                        </ComboBox.Items>
                    </ComboBox>
                </Grid>

                <!-- Blur Radius -->
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ThemeBlurLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeBlurHint}" />
                    <Slider Grid.Column="1"
                            Minimum="0" Maximum="60"
                            Value="{Binding BlurRadius, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding BlurRadius, StringFormat={}{0:F0}}"
                               Foreground="{DynamicResource VP.TextTertiaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="11" />
                </Grid>

                <!-- Glass Opacity -->
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ThemeOpacityLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeOpacityHint}" />
                    <Slider Grid.Column="1"
                            Minimum="0.1" Maximum="1.0"
                            Value="{Binding GlassOpacity, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding GlassOpacity, StringFormat={}{0:F1}}"
                               Foreground="{DynamicResource VP.TextTertiaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="11" />
                </Grid>

                <!-- Auto Text Contrast -->
                <Separator Margin="14,0" />
                <Grid Margin="14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ThemeAutoContrastLabel}"
                               Style="{StaticResource SettingsLabelStyle}"
                               ToolTip="{loc:Loc ThemeAutoContrastHint}" />
                    <CheckBox Grid.Column="1"
                              Style="{DynamicResource VP.CheckBox}"
                              IsChecked="{Binding AutoTextContrast}"
                              Content="{loc:Loc ThemeAutoContrastOption}" />
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
