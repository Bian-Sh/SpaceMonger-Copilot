<UserControl x:Class="SpaceMonger.App.Views.TreeViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TreeViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!-- Minimal toggle style for expand/collapse glyph: no hover/pressed background visuals -->
        <Style x:Key="ExpandToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TreeHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TreeCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TreeNumericText" TargetType="TextBlock" BasedOn="{StaticResource TreeCellText}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TreeHeaderButton" TargetType="Button" BasedOn="{StaticResource VP.ButtonIcon}">
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeColumnBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource VP.BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0.5,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource VP.SurfaceBrush}"
                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                BorderThickness="0.5,0.5,0.5,0"
                CornerRadius="10,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="142" />
                    <ColumnDefinition Width="92" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortByNameCommand}">
                    <TextBlock Style="{StaticResource TreeHeaderText}" Text="文件夹" />
                </Button>
                <Button Grid.Column="1" Style="{StaticResource TreeHeaderButton}" HorizontalContentAlignment="Right" Command="{Binding SortBySizeCommand}">
                    <TextBlock Style="{StaticResource TreeHeaderText}" Text="父级百分比" TextAlignment="Right" />
                </Button>
                <Button Grid.Column="2" Style="{StaticResource TreeHeaderButton}" HorizontalContentAlignment="Right" Command="{Binding SortBySizeCommand}">
                    <TextBlock Style="{StaticResource TreeHeaderText}" Text="大小" TextAlignment="Right" />
                </Button>
                <TextBlock Grid.Column="3" Style="{StaticResource TreeHeaderText}" Text="分配" TextAlignment="Right" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <TextBlock Grid.Column="4" Style="{StaticResource TreeHeaderText}" Text="项目" TextAlignment="Right" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <TextBlock Grid.Column="5" Style="{StaticResource TreeHeaderText}" Text="文件" TextAlignment="Right" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <TextBlock Grid.Column="6" Style="{StaticResource TreeHeaderText}" Text="文件夹" TextAlignment="Right" HorizontalAlignment="Right" Margin="0,0,8,0" />
                <Button Grid.Column="7" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortByModifiedCommand}">
                    <TextBlock Style="{StaticResource TreeHeaderText}" Text="修改时间" />
                </Button>
                <TextBlock Grid.Column="8" Style="{StaticResource TreeHeaderText}" Text="属性" Margin="8,0" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource VP.BackgroundBrush}"
                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                BorderThickness="0.5,0,0.5,0.5"
                CornerRadius="0,0,10,10">
            <TreeView x:Name="FileTreeView"
                      ItemsSource="{Binding RootItems}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      TreeViewItem.Selected="TreeViewItem_Selected">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <EventSetter Event="MouseRightButtonDown" Handler="TreeViewItem_MouseRightButtonDown" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="Bd" Background="Transparent" BorderThickness="0">
                                            <ContentPresenter x:Name="PART_Header"
                                                              ContentSource="Header"
                                                              HorizontalAlignment="Stretch" />
                                        </Border>
                                        <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D6CDF" />
                                            <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected" Value="False" />
                                            </MultiTrigger.Conditions>
                                            <!-- keep hit-testing by using Transparent, but remove visible hover background -->
                                            <Setter TargetName="Bd" Property="Background" Value="Transparent" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:TreeViewItemViewModel}" ItemsSource="{Binding Children}">
                        <Grid Height="24" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="430" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource TreeColumnBorder}">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding IndentLevels}"
                                                  HorizontalAlignment="Left"
                                                  Width="{Binding IndentWidth}"
                                                  IsHitTestVisible="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="16" BorderBrush="{StaticResource VP.BorderSubtleBrush}" BorderThickness="0,0,0.5,0" Opacity="0.45" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="{Binding IndentMargin}">
                                        <!-- connector for items that have children: placed to the LEFT of the foldout triangle -->
                                        <Rectangle Width="18"
                                                   Height="0.5"
                                                   Fill="{StaticResource VP.BorderSubtleBrush}"
                                                   Opacity="0.45"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   IsHitTestVisible="False"
                                                   Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <ToggleButton Width="32"
                                                      Height="32"
                                                      Margin="0,0,2,0"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Style="{StaticResource ExpandToggleStyle}"
                                                      FocusVisualStyle="{x:Null}">
                                        <TextBlock Text="▸" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform Y="-5" />
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <!-- rotate when the bound viewmodel node is expanded -->
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="90" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>

                                                        <!-- hover and pressed change only the icon color (no background changes) -->
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource VP.AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        </ToggleButton>

                                        <!-- connector for items without children: directly connects to the entity icon/text -->
                                        <Rectangle Width="18"
                                                   Height="0.5"
                                                   Fill="{StaticResource VP.BorderSubtleBrush}"
                                                   Opacity="0.45"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   IsHitTestVisible="False"
                                                   Visibility="{Binding HasNoChildren, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource TreeCellText}"
                                                   ToolTip="{Binding Entry.Path}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource TreeColumnBorder}" Padding="4,2">
                                <Grid>
                                    <Border Height="18" BorderBrush="{StaticResource VP.BorderSubtleBrush}" BorderThickness="0.5" Background="#102C4A" />
                                    <Border Height="18" HorizontalAlignment="Left" Width="{Binding ParentPercentBarWidth}" Background="#6F86FF" Opacity="0.9" />
                                    <TextBlock Text="{Binding ParentPercentText}" Style="{StaticResource TreeNumericText}" Foreground="{StaticResource VP.TextPrimaryBrush}" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding SizeText}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding AllocatedText}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding ItemCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="5" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding FileCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="6" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding FolderCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="7" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding ModifiedText}" Style="{StaticResource TreeCellText}" Margin="8,0" />
                            </Border>
                            <Border Grid.Column="8" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding AttributeText}" Style="{StaticResource TreeCellText}" Margin="8,0" />
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </Grid>
</UserControl>

