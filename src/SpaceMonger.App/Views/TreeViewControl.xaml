<UserControl x:Class="SpaceMonger.App.Views.TreeViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TreeViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!-- Minimal toggle style for expand/collapse glyph: no hover/pressed background visuals -->
        <Style x:Key="ExpandToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TreeHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="TreeCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TreeNumericText" TargetType="TextBlock" BasedOn="{StaticResource TreeCellText}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TreeHeaderButton" TargetType="Button" BasedOn="{StaticResource VP.ButtonIcon}">
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeColumnBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource VP.BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0.5,0" />
        </Style>

        <Style x:Key="TreeHeaderSplitter" TargetType="GridSplitter">
            <Setter Property="Width" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="ResizeBehavior" Value="CurrentAndNext" />
            <Setter Property="ShowsPreview" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Margin" Value="0,0,-2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Rectangle x:Name="DividerLine" Width="1" Fill="{StaticResource VP.BorderSubtleBrush}" Opacity="0.5" HorizontalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DividerLine" Property="Width" Value="2" />
                                <Setter TargetName="DividerLine" Property="Opacity" Value="0.8" />
                                <Setter TargetName="DividerLine" Property="Fill" Value="{StaticResource VP.TextSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="HeaderScrollViewer" Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False">
            <Border
                Background="{StaticResource VP.BackgroundBrush}"
                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                BorderThickness="0.5,0.5,0.5,0"
                CornerRadius="0">
                <Grid x:Name="HeaderContentGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="225" SharedSizeGroup="col0" />
                        <ColumnDefinition Width="Auto" MinWidth="90" SharedSizeGroup="col1" />
                        <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="col2" />
                        <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="col3" />
                        <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col4" />
                        <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col5" />
                        <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col6" />
                        <ColumnDefinition Width="Auto" MinWidth="130" SharedSizeGroup="col7" />
                        <ColumnDefinition Width="Auto" MinWidth="100" SharedSizeGroup="col8" />
                        <ColumnDefinition x:Name="HeaderSpacerColumn" Width="0" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortByNameCommand}">
                        <TextBlock Style="{StaticResource TreeHeaderText}" Text="文件夹" />
                    </Button>
                    <GridSplitter Grid.Column="0" Style="{StaticResource TreeHeaderSplitter}" />

                    <Button Grid.Column="1" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortBySizeCommand}">
                        <TextBlock Style="{StaticResource TreeHeaderText}" Text="父级百分比" />
                    </Button>
                    <GridSplitter Grid.Column="1" Style="{StaticResource TreeHeaderSplitter}" />

                    <Button Grid.Column="2" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortBySizeCommand}">
                        <TextBlock Style="{StaticResource TreeHeaderText}" Text="大小" />
                    </Button>
                    <GridSplitter Grid.Column="2" Style="{StaticResource TreeHeaderSplitter}" />

                    <TextBlock Grid.Column="3" Style="{StaticResource TreeHeaderText}" Text="分配" Margin="0,0,8,0" />
                    <GridSplitter Grid.Column="3" Style="{StaticResource TreeHeaderSplitter}" />

                    <TextBlock Grid.Column="4" Style="{StaticResource TreeHeaderText}" Text="项目" Margin="0,0,8,0" />
                    <GridSplitter Grid.Column="4" Style="{StaticResource TreeHeaderSplitter}" />

                    <TextBlock Grid.Column="5" Style="{StaticResource TreeHeaderText}" Text="文件" Margin="0,0,8,0" />
                    <GridSplitter Grid.Column="5" Style="{StaticResource TreeHeaderSplitter}" />

                    <TextBlock Grid.Column="6" Style="{StaticResource TreeHeaderText}" Text="文件夹" Margin="0,0,8,0" />
                    <GridSplitter Grid.Column="6" Style="{StaticResource TreeHeaderSplitter}" />

                    <Button Grid.Column="7" Style="{StaticResource TreeHeaderButton}" Command="{Binding SortByModifiedCommand}">
                        <TextBlock Style="{StaticResource TreeHeaderText}" Text="修改时间" />
                    </Button>
                    <GridSplitter Grid.Column="7" Style="{StaticResource TreeHeaderSplitter}" />

                    <TextBlock Grid.Column="8" Style="{StaticResource TreeHeaderText}" Text="属性" Margin="8,0" />
                    <GridSplitter Grid.Column="8" Style="{StaticResource TreeHeaderSplitter}" />
                </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource VP.BackgroundBrush}"
                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                BorderThickness="0.5,0,0.5,0.5"
                CornerRadius="0,0,10,10">
            <TreeView x:Name="FileTreeView"
                      ItemsSource="{Binding RootItems}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      TreeViewItem.Selected="TreeViewItem_Selected">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <EventSetter Event="MouseRightButtonDown" Handler="TreeViewItem_MouseRightButtonDown" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="Bd" Background="Transparent" BorderThickness="0">
                                            <ContentPresenter x:Name="PART_Header"
                                                              ContentSource="Header"
                                                              HorizontalAlignment="Stretch" />
                                        </Border>
                                        <Border Height="0" BorderBrush="{StaticResource VP.BorderSubtleBrush}" BorderThickness="0,0,0,0.5" Opacity="0.35" />
                                        <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D6CDF" />
                                            <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected" Value="False" />
                                            </MultiTrigger.Conditions>
                                            <!-- keep hit-testing by using Transparent, but remove visible hover background -->
                                            <Setter TargetName="Bd" Property="Background" Value="Transparent" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:TreeViewItemViewModel}" ItemsSource="{Binding Children}">
                        <Grid Height="24" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="225" SharedSizeGroup="col0" />
                                <ColumnDefinition Width="Auto" MinWidth="90" SharedSizeGroup="col1" />
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="col2" />
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="col3" />
                                <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col4" />
                                <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col5" />
                                <ColumnDefinition Width="Auto" MinWidth="60" SharedSizeGroup="col6" />
                                <ColumnDefinition Width="Auto" MinWidth="130" SharedSizeGroup="col7" />
                                <ColumnDefinition Width="Auto" MinWidth="100" SharedSizeGroup="col8" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource TreeColumnBorder}">
                                <Grid>
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <controls:TreeGuideControl Segments="{Binding TreeGuideSegments}"
                                                                   HasParent="{Binding HasParent}"
                                                                   IsLastChild="{Binding IsLastChild}"
                                                                   HasChildren="{Binding HasChildren}"
                                                                   IsDebugColored="False"
                                                                   Height="24"
                                                                   IsHitTestVisible="False" />

                                        <ToggleButton Width="18"
                                                      Height="24"
                                                      HorizontalAlignment="Left"
                                                      Margin="{Binding ToggleMargin}"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Style="{StaticResource ExpandToggleStyle}"
                                                      FocusVisualStyle="{x:Null}">
                                            <TextBlock Text="▸"
                                                       FontSize="24"
                                                       LineHeight="24"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="0" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="90" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource VP.AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToggleButton>

                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Margin="{Binding IconMargin}">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{StaticResource VP.TextSecondaryBrush}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource TreeCellText}"
                                                       ToolTip="{Binding Entry.Path}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource TreeColumnBorder}" Padding="4,2">
                                <Grid>
                                    <Border Height="18" BorderBrush="{StaticResource VP.BorderSubtleBrush}" BorderThickness="0.5" Background="#102C4A" />
                                    <Border Height="18" HorizontalAlignment="Left" Width="{Binding ParentPercentBarWidth}" Background="#6F86FF" Opacity="0.9" />
                                    <TextBlock Text="{Binding ParentPercentText}" Style="{StaticResource TreeNumericText}" Foreground="{StaticResource VP.TextPrimaryBrush}" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding SizeText}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding AllocatedText}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding ItemCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="5" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding FileCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="6" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding FolderCount}" Style="{StaticResource TreeNumericText}" />
                            </Border>
                            <Border Grid.Column="7" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding ModifiedText}" Style="{StaticResource TreeCellText}" Margin="8,0" />
                            </Border>
                            <Border Grid.Column="8" Style="{StaticResource TreeColumnBorder}">
                                <TextBlock Text="{Binding AttributeText}" Style="{StaticResource TreeCellText}" Margin="8,0" />
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </Grid>
</UserControl>

