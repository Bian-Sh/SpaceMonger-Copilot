<UserControl x:Class="SpaceMonger.App.Views.RecommendationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RecommendationsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:SafetyRatingToBrushConverter x:Key="SafetyRatingToBrushConverter" />

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Filter Bar -->
        <DockPanel Grid.Row="0"
                   Margin="8"
                   LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Content="{loc:Loc AnalyzeButton}"
                    Padding="12,4"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTipService.ShowOnDisabled="True"
                    Click="AnalyzeButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled" Value="True" />
                        <Setter Property="ToolTip" Value="{loc:Loc RecommendCleanupToolTip}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="ToolTip" Value="{loc:Loc AnalysisInProgressToolTip}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
            <Label Content="{loc:Loc FilterByLabel}"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0" />

            <!-- Category Filter -->
            <ComboBox Width="160"
                      Margin="0,0,8,0"
                      SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}">
                <ComboBox.Items>
                    <ComboBoxItem Content="{loc:Loc AllCategoriesOption}" Tag="" IsSelected="True" />
                    <enums:RecommendationCategory>TemporaryFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>BuildCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>PackageManagerCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>OldDownloads</enums:RecommendationCategory>
                    <enums:RecommendationCategory>LogFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>DuplicateFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>BrowserCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>SystemCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>Other</enums:RecommendationCategory>
                </ComboBox.Items>
            </ComboBox>

            <!-- Safety Filter -->
            <ComboBox Width="140"
                      Margin="0,0,8,0"
                      SelectedItem="{Binding SelectedSafetyFilter, Mode=TwoWay}">
                <ComboBox.Items>
                    <ComboBoxItem Content="{loc:Loc AllRatingsOption}" Tag="" IsSelected="True" />
                    <enums:SafetyRating>Safe</enums:SafetyRating>
                    <enums:SafetyRating>ReviewFirst</enums:SafetyRating>
                    <enums:SafetyRating>Caution</enums:SafetyRating>
                </ComboBox.Items>
            </ComboBox>

            <Button Content="{loc:Loc SelectAllSafeButton}"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    Command="{Binding SelectAllSafeCommand}" />

            <Button Content="{loc:Loc DeselectAllCautionButton}"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    Command="{Binding DeselectAllCautionCommand}" />
        </StackPanel>
        </DockPanel>

        <!-- Analyzing overlay (covers rows 1-2) -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#F5F5F5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="16" Margin="0,0,0,8" />
                <TextBlock Text="{loc:Loc AnalyzingFilesText}"
                           FontSize="14"
                           Foreground="#555555"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Loc AnalysisMayTakeText}"
                           FontSize="11"
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Error / empty display (covers rows 1-2) -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Panel.ZIndex="5"
                Background="#FAFAFA"
                Padding="20">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsAnalyzing}" Value="False" />
                                <Condition Binding="{Binding HasRecommendations}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                <TextBlock Text="{Binding AnalysisError}"
                           TextWrapping="Wrap"
                           Foreground="#D32F2F"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{loc:Loc RecommendationsEmptyTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{loc:Loc RecommendationsEmptyDescription}"
                           TextWrapping="Wrap"
                           Foreground="#777777"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: Recommendations List -->
        <ListView x:Name="RecommendationsList"
                  Grid.Row="1"
                  ItemsSource="{Binding FilteredRecommendations}"
                  Margin="8,0,8,8"
                  BorderThickness="1"
                  BorderBrush="#CCCCCC"
                  MouseDoubleClick="RecommendationsList_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  AlternationCount="2">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="#FFFFFF" />
                    <EventSetter Event="RequestBringIntoView" Handler="RecommendationItem_RequestBringIntoView" />
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#F7FAFD" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E3F2FD" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Recommendation Id -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Id}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#666666" />

                        <!-- File Path -->
                        <Button Grid.Row="0" Grid.Column="1"
                                Padding="0"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="RecommendationPath_Click"
                                ToolTip="{Binding TargetPath}">
                            <TextBlock Text="{Binding TargetPath}"
                                       TextTrimming="CharacterEllipsis" />
                        </Button>

                        <!-- Size -->
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontWeight="SemiBold" />

                        <!-- Safety Rating Badge -->
                        <Border Grid.Row="0" Grid.Column="3"
                                Background="{Binding SafetyRating, Converter={StaticResource SafetyRatingToBrushConverter}}"
                                CornerRadius="4"
                                Padding="6,2"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding SafetyRating}"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>

                        <!-- CheckBox -->
                        <CheckBox Grid.Row="0" Grid.Column="4"
                                  IsChecked="{Binding IsAccepted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Checked="RecommendationSelectionChanged"
                                  Unchecked="RecommendationSelectionChanged"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0" />

                        <!-- Explanation (spans data columns, below the main row) -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    Margin="0,2,0,0">
                            <TextBlock Text="{Binding Category}"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Explanation}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Foreground="#888888" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Row 2: Summary Bar -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <Run Text="{loc:Loc SelectedLabel}" />
                    <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="{loc:Loc ItemsLabel}" />
                </TextBlock>

                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <Run Text="{loc:Loc RecoverableLabel}" />
                    <Run Text="{Binding TotalRecoverableSpace, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>

                <Button Content="{loc:Loc CleanUpButton}"
                        Padding="12,4"
                        Click="CleanUpButton_Click"
                        ToolTip="{loc:Loc CleanUpToolTip}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
