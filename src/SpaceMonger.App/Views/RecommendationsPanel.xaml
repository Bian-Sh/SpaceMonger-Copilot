<UserControl x:Class="SpaceMonger.App.Views.RecommendationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RecommendationsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:SafetyRatingToBrushConverter x:Key="SafetyRatingToBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Filter Bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="8"
                    VerticalAlignment="Center">
            <Label Content="Filter by:"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0" />

            <!-- Category Filter -->
            <ComboBox Width="160"
                      Margin="0,0,8,0"
                      SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}">
                <ComboBox.Items>
                    <ComboBoxItem Content="All Categories" IsSelected="True" />
                    <enums:RecommendationCategory>TemporaryFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>BuildCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>PackageManagerCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>OldDownloads</enums:RecommendationCategory>
                    <enums:RecommendationCategory>LogFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>DuplicateFiles</enums:RecommendationCategory>
                    <enums:RecommendationCategory>BrowserCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>SystemCache</enums:RecommendationCategory>
                    <enums:RecommendationCategory>Other</enums:RecommendationCategory>
                </ComboBox.Items>
            </ComboBox>

            <!-- Safety Filter -->
            <ComboBox Width="140"
                      Margin="0,0,8,0"
                      SelectedItem="{Binding SelectedSafetyFilter, Mode=TwoWay}">
                <ComboBox.Items>
                    <ComboBoxItem Content="All Ratings" IsSelected="True" />
                    <enums:SafetyRating>Safe</enums:SafetyRating>
                    <enums:SafetyRating>ReviewFirst</enums:SafetyRating>
                    <enums:SafetyRating>Caution</enums:SafetyRating>
                </ComboBox.Items>
            </ComboBox>

            <Button Content="Select All Safe"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    Command="{Binding SelectAllSafeCommand}" />

            <Button Content="Deselect All Caution"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    Command="{Binding DeselectAllCautionCommand}" />
        </StackPanel>

        <!-- Row 1: Recommendations List -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding FilteredRecommendations}"
                  Margin="8,0,8,8"
                  BorderThickness="1"
                  BorderBrush="#CCCCCC"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- CheckBox -->
                        <CheckBox Grid.Row="0" Grid.Column="0"
                                  IsChecked="{Binding IsAccepted, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />

                        <!-- File Path -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TargetPath}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding TargetPath}"
                                   Margin="0,0,8,0" />

                        <!-- Size -->
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontWeight="SemiBold" />

                        <!-- Safety Rating Badge -->
                        <Border Grid.Row="0" Grid.Column="3"
                                Background="{Binding SafetyRating, Converter={StaticResource SafetyRatingToBrushConverter}}"
                                CornerRadius="4"
                                Padding="6,2"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding SafetyRating}"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Border>

                        <!-- Explanation (spans columns 1-3, below the main row) -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    Margin="0,2,0,0">
                            <TextBlock Text="{Binding Category}"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Explanation}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Foreground="#888888" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Row 2: Summary Bar -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <Run Text="Selected: " />
                    <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text=" items" />
                </TextBlock>

                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <Run Text="Recoverable: " />
                    <Run Text="{Binding TotalRecoverableSpace, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>

                <Button Content="Clean Up"
                        Padding="12,4"
                        Click="CleanUpButton_Click"
                        ToolTip="Execute cleanup for selected recommendations" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
