<UserControl x:Class="SpaceMonger.App.Views.RecommendationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RecommendationsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="800"
             FontFamily="{DynamicResource VP.FontFamily}">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:SafetyRatingToBrushConverter x:Key="SafetyRatingToBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Filter Bar (hidden when no recommendations) -->
        <Border x:Name="FilterBar"
                Grid.Row="0"
                Margin="0,2,0,4"
                Padding="20,2,10,2"
                Background="{DynamicResource VP.SurfaceBrush}"
                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                BorderThickness="0.5"
                >
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasRecommendations}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Style="{DynamicResource VP.CheckBox}"
                              IsThreeState="True"
                              IsChecked="{Binding AllRecommendationsSelectionState, Mode=OneWay}"
                              Command="{Binding ToggleAllRecommendationsCommand}"
                              VerticalAlignment="Center" />

                    <Button Content="{loc:Loc SelectAllSafeButton}"
                            Style="{DynamicResource VP.Button}"
                            Padding="8,4"
                            Margin="0,0,4,0"
                            Command="{Binding SelectAllSafeCommand}" />

                    <Button Content="{loc:Loc DeselectAllCautionButton}"
                            Style="{DynamicResource VP.Button}"
                            Padding="8,4"
                            Margin="0,0,4,0"
                            Command="{Binding DeselectAllCautionCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc FilterByLabel}"
                               Foreground="{DynamicResource VP.TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <ComboBox Width="140"
                              Margin="0,0,4,0"
                              Style="{DynamicResource VP.ComboBox}"
                              SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}">
                        <ComboBox.Items>
                            <ComboBoxItem Content="{loc:Loc AllCategoriesOption}" Tag="" IsSelected="True" />
                            <enums:RecommendationCategory>TemporaryFiles</enums:RecommendationCategory>
                            <enums:RecommendationCategory>BuildCache</enums:RecommendationCategory>
                            <enums:RecommendationCategory>PackageManagerCache</enums:RecommendationCategory>
                            <enums:RecommendationCategory>OldDownloads</enums:RecommendationCategory>
                            <enums:RecommendationCategory>LogFiles</enums:RecommendationCategory>
                            <enums:RecommendationCategory>DuplicateFiles</enums:RecommendationCategory>
                            <enums:RecommendationCategory>BrowserCache</enums:RecommendationCategory>
                            <enums:RecommendationCategory>SystemCache</enums:RecommendationCategory>
                            <enums:RecommendationCategory>Other</enums:RecommendationCategory>
                        </ComboBox.Items>
                    </ComboBox>

                    <ComboBox Width="130"
                              Style="{DynamicResource VP.ComboBox}"
                              SelectedItem="{Binding SelectedSafetyFilter, Mode=TwoWay}">
                        <ComboBox.Items>
                            <ComboBoxItem Content="{loc:Loc AllRatingsOption}" Tag="" IsSelected="True" />
                            <enums:SafetyRating>Safe</enums:SafetyRating>
                            <enums:SafetyRating>ReviewFirst</enums:SafetyRating>
                            <enums:SafetyRating>Caution</enums:SafetyRating>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Analyzing overlay -->
        <Border Grid.Row="1"
                Panel.ZIndex="10"
                Background="Transparent"
                Padding="0,8,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="3" Margin="0,0,0,12"
                             Foreground="{DynamicResource VP.AccentBrush}"
                             Background="{DynamicResource VP.SurfaceBrush}" />
                <TextBlock Text="{loc:Loc AnalyzingFilesText}"
                           FontSize="14"
                           Foreground="{DynamicResource VP.TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Loc AnalysisMayTakeText}"
                           FontSize="11"
                           Foreground="{DynamicResource VP.TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Error / empty display -->
        <Border Grid.Row="1"
                Panel.ZIndex="5"
                Background="Transparent"
                Padding="20">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsAnalyzing}" Value="False" />
                                <Condition Binding="{Binding HasRecommendations}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                <TextBlock Text="{Binding AnalysisError}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource VP.DangerBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{loc:Loc RecommendationsEmptyTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource VP.TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{loc:Loc RecommendationsEmptyDescription}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource VP.TextSecondaryBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AnalysisError, TargetNullValue=''}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: Recommendations List -->
        <ListView x:Name="RecommendationsList"
                  Grid.Row="1"
                  Style="{DynamicResource VP.ListView}"
                  ItemsSource="{Binding FilteredRecommendations}"
                  Margin="4,0,4,4"
                  Padding="0"
                  MouseDoubleClick="RecommendationsList_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource VP.ListViewItem}">
                    <EventSetter Event="RequestBringIntoView" Handler="RecommendationItem_RequestBringIntoView" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource VP.CardBrush}"
                            BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                            BorderThickness="0.5"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="2,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- CheckBox -->
                            <CheckBox Grid.Row="0" Grid.Column="0"
                                      Style="{DynamicResource VP.CheckBox}"
                                      IsChecked="{Binding IsAccepted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Checked="RecommendationSelectionChanged"
                                      Unchecked="RecommendationSelectionChanged"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                            <!-- File Path -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource VP.TextPrimaryBrush}"
                                    Click="RecommendationPath_Click"
                                    ToolTip="{Binding TargetPath}">
                                <TextBlock Text="{Binding TargetPath}"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12.5" />
                            </Button>

                            <!-- Size -->
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource VP.TextPrimaryBrush}" />

                            <!-- Safety Badge -->
                            <Border Grid.Row="0" Grid.Column="3"
                                    Background="{Binding SafetyRating, Converter={StaticResource SafetyRatingToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding SafetyRating}"
                                           Foreground="White"
                                           FontSize="10.5"
                                           FontWeight="SemiBold" />
                            </Border>

                            <!-- Category + Explanation -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        Margin="0,3,0,0">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="11"
                                           Foreground="{DynamicResource VP.TextTertiaryBrush}"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Explanation}"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{DynamicResource VP.TextTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Row 2: Summary Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource VP.SurfaceBrush}"
                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,10,10"
                Padding="10,5">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{loc:Loc CleanUpButton}"
                            Padding="16,5"
                            Click="CleanUpButton_Click"
                            ToolTipService.ShowOnDisabled="True"
                            ToolTip="{loc:Loc CleanUpToolTip}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource VP.DangerButton}">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TotalSelectedCount}" Value="0">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="ToolTip" Value="{loc:Loc NoItemsSelectedForCleanupToolTip}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{loc:Loc AnalyzeButton}"
                            Padding="16,5"
                            Margin="6,0,0,0"
                            Click="AnalyzeButton_Click"
                            ToolTipService.ShowOnDisabled="True"
                            ToolTip="{loc:Loc RecommendCleanupToolTip}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource VP.AccentButton}">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="ToolTip" Value="{loc:Loc AnalysisInProgressToolTip}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource VP.TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center">
                        <Run Text="{loc:Loc SelectedLabel}" />
                        <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource VP.TextPrimaryBrush}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalItemCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource VP.TextPrimaryBrush}" />
                        <Run Text="{loc:Loc ItemsLabel}" />
                    </TextBlock>

                    <Rectangle Width="1" Height="12" Margin="0,0,16,0"
                               Fill="{DynamicResource VP.BorderSubtleBrush}"
                               VerticalAlignment="Center" />

                    <TextBlock Foreground="{DynamicResource VP.TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center">
                        <Run Text="{loc:Loc RecoverableLabel}" />
                        <Run Text="{Binding TotalRecoverableSpace, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource VP.TextPrimaryBrush}" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
