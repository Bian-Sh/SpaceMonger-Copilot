<UserControl x:Class="SpaceMonger.App.Views.TreemapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="0,0,4,0">
        <!-- Treemap area: rounded container with clip -->
        <Border x:Name="TreemapContainer"
                CornerRadius="0,0,10,10"
                ClipToBounds="True"
                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                BorderThickness="0.5,0,0.5,0.5">
            <Grid>
                <controls:TreemapControl x:Name="Treemap"
                                         NodeClicked="Treemap_NodeClicked"
                                         NodeHovered="Treemap_NodeHovered"
                                         NodeRightClicked="Treemap_NodeRightClicked"
                                         SizeChanged="Treemap_SizeChanged" />

                <!-- Empty state: text overlay on canvas, no background panel -->
                <StackPanel x:Name="EmptyStatePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="40"
                               Foreground="{StaticResource VP.TextTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                    <TextBlock x:Name="EmptyStateTitle"
                               Text="{loc:Loc TreemapEmptyTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VP.TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptyStateHint"
                               Text="{loc:Loc TreemapEmptyHint}"
                               FontSize="13"
                               Foreground="{StaticResource VP.TextTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0" Visibility="Collapsed" />
                </StackPanel>

                <!-- Scanning overlay -->
                <Border x:Name="ScanningOverlay"
                        Background="{StaticResource VP.OverlayBrush}"
                        CornerRadius="0,0,10,10"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Loc ScanningStatus}"
                                   FontSize="24"
                                   FontWeight="Light"
                                   Foreground="{StaticResource VP.TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="ScanProgressText"
                                   FontSize="14"
                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                        <Button Content="{loc:Loc CancelButton}"
                                Style="{StaticResource VP.Button}"
                                Padding="20,8"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding DataContext.CancelScanCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="{loc:Loc CancelScanToolTip}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
