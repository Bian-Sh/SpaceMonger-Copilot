<UserControl x:Class="SpaceMonger.App.Views.TreemapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Breadcrumb bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Background="#F0F0F0">
            <Button x:Name="UpButton"
                    Content="{loc:Loc UpButton}"
                    Padding="6,2"
                    Margin="4,0"
                    IsEnabled="False"
                    Click="UpButton_Click"
                    ToolTip="{loc:Loc NavigateUpToolTip}" />
            <StackPanel x:Name="BreadcrumbPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="4,0" />
        </StackPanel>

        <!-- Row 1: TreemapControl -->
        <Grid Grid.Row="1">
            <controls:TreemapControl x:Name="Treemap"
                                     NodeClicked="Treemap_NodeClicked"
                                     NodeHovered="Treemap_NodeHovered"
                                     NodeRightClicked="Treemap_NodeRightClicked"
                                     SizeChanged="Treemap_SizeChanged" />
            <TextBlock x:Name="NoDataText"
                       Text="无数据"
                       Foreground="#C8C8C8"
                       FontSize="22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <Border x:Name="ScanningOverlay"
                    Background="#80000000"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Loc ScanningStatus}"
                               FontSize="24"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="ScanProgressText"
                               FontSize="14"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
