<UserControl x:Class="SpaceMonger.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             xmlns:theme="clr-namespace:SpaceMonger.Core.Models.Theme;assembly=SpaceMonger.Core"
             xmlns:converters="clr-namespace:SpaceMonger.App.Converters"
             xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
             FontFamily="{DynamicResource VP.FontFamily}">

    <UserControl.Resources>
        <converters:HexColorConverter x:Key="HexColorConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource VP.TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="120" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        </Style>

        <!-- Theme preset card style -->
        <Style x:Key="ThemePresetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource VP.SettingsCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource VP.BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Width" Value="150" />
        </Style>

        <Style x:Key="SettingsNavButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource VP.SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Back button style -->
        <Style x:Key="SettingsBackButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource VP.SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource VP.BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource VP.DangerBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource VP.DangerPressedBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource VP.OverlayBrush}" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">
        <!-- Centered card -->
        <Border x:Name="CardBorder" Background="{DynamicResource VP.BackgroundAltBrush}"
                BorderBrush="{DynamicResource VP.BorderLightBrush}"
                BorderThickness="1"
                MaxWidth="720"
                MaxHeight="580"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="124" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="16,46,8,20">
                    <StackPanel>
                        <Button x:Name="ApiNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc AnthropicApiKeyHeader}"
                                Tag="ApiSectionAnchor"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="GeneralNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc SettingsGeneralNav}"
                                Tag="GeneralSectionAnchor"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="ThemeNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc ThemeSectionLabel}"
                                Tag="ThemeSectionAnchor"
                                Click="SettingsNavButton_Click" />
                    </StackPanel>
                </Grid>
                <!-- Scrollable content -->

                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,56,20,18" ScrollChanged="SettingsScrollViewer_ScrollChanged">
                    <StackPanel x:Name="SettingsContentPanel" SizeChanged="SettingsContentPanel_SizeChanged">

                        <!-- ═══════ Anthropic API Section ═══════ -->
                        <TextBlock x:Name="ApiSectionAnchor" Text="{loc:Loc AnthropicApiKeyHeader}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource VP.TextSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <Border x:Name="ApiSection" Background="{DynamicResource VP.SettingsCardBrush}"
                                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="API Key"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ApiKeyToolTip}" />
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Style="{DynamicResource VP.TextBox}"
                                                     Width="240"
                                                     Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="AutoSaveOnLostFocus" />
                                            <Button Content="{loc:Loc ValidateButton}"
                                                    Style="{DynamicResource VP.AccentButton}"
                                                    Margin="8,0,0,0"
                                                    Command="{Binding ValidateCommand}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding ValidationStatusText}"
                                                   Margin="0,6,0,0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource VP.TextTertiaryBrush}" />
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ValidationState}"
                                                                     Value="{x:Static vm:ValidationState.Validating}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValidationState}"
                                                                     Value="{x:Static vm:ValidationState.Valid}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Foreground" Value="{DynamicResource VP.SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValidationState}"
                                                                     Value="{x:Static vm:ValidationState.Invalid}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Foreground" Value="{DynamicResource VP.DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsBaseUrlLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsBaseUrlHint}" />
                                    <TextBox Grid.Column="1" Style="{DynamicResource VP.TextBox}"
                                             Text="{Binding AnthropicBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsAnalysisModelLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsAnalysisModelHint}" />
                                    <TextBox Grid.Column="1" Style="{DynamicResource VP.TextBox}"
                                             Text="{Binding AnalysisModelName, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsChatModelLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsChatModelHint}" />
                                    <TextBox Grid.Column="1" Style="{DynamicResource VP.TextBox}"
                                             Text="{Binding ChatModelName, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsThinkingLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsThinkingHint}" />
                                    <CheckBox Grid.Column="1"
                                              Style="{DynamicResource VP.CheckBox}"
                                              IsChecked="{Binding EnableThinking}"
                                              VerticalAlignment="Center"
                                              Content="{loc:Loc SettingsAllowThinkingOption}"
                                              Click="AutoSaveOnChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══════ General Section ═══════ -->
                        <TextBlock x:Name="GeneralSectionAnchor" Text="{loc:Loc SettingsGeneralNav}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource VP.TextSecondaryBrush}"
                                   Margin="0,16,0,10" />
                        <Border x:Name="GeneralSection" Background="{DynamicResource VP.SettingsCardBrush}"
                                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsLanguageLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsLanguageHint}" />
                                    <ComboBox Grid.Column="1"
                                              Style="{DynamicResource VP.ComboBox}"
                                              ItemsSource="{x:Static vm:SettingsViewModel.LanguageOptions}"
                                              SelectedValue="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Code"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="AutoSaveOnChanged" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsDefaultCleanupModeLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsDefaultCleanupModeHint}" />
                                    <ComboBox Grid.Column="1"
                                              Style="{DynamicResource VP.ComboBox}"
                                              SelectedItem="{Binding SelectedDeletionMode}"
                                              SelectionChanged="AutoSaveOnChanged">
                                        <ComboBox.Items>
                                            <enums:DeletionMode>MoveToRecycleBin</enums:DeletionMode>
                                            <enums:DeletionMode>PermanentDelete</enums:DeletionMode>
                                        </ComboBox.Items>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══════ Theme Section ═══════ -->
                        <TextBlock x:Name="ThemeSectionAnchor" Text="{loc:Loc ThemeSectionLabel}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource VP.TextSecondaryBrush}"
                                   Margin="0,16,0,10" />

                        <Border x:Name="ThemeSection" Background="{DynamicResource VP.SettingsCardBrush}"
                                BorderBrush="{DynamicResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <!-- Theme Color Picker + Presets inline -->
                                <Grid Margin="14,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{loc:Loc ThemeAccentColorLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeAccentColorHint}"
                                               Margin="0,0,0,8" />

                                    <!-- Presets row -->
                                    <ItemsControl Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{x:Static vm:SettingsViewModel.AvailableThemePresets}"
                                                  Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type theme:ThemeProfile}">
                                                <Border Style="{StaticResource ThemePresetCardStyle}"
                                                        MouseLeftButtonDown="ThemePreset_Click"
                                                        Tag="{Binding}"
                                                        Width="Auto" Margin="0,0,6,0" Padding="10,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="14" Height="14" Margin="0,0,6,0">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource HexColorConverter}}" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource VP.TextPrimaryBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Color Picker -->
                                    <controls:ColorPickerControl x:Name="ThemeColorPicker"
                                        Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        SelectedColor="{Binding ThemeBackgroundColor, Mode=TwoWay}" />
                                </Grid>

                                <!-- Glass / Frosted Glass Toggle -->
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc ThemeGlassLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeGlassHint}" />
                                    <CheckBox Grid.Column="1"
                                              Style="{DynamicResource VP.CheckBox}"
                                              IsChecked="{Binding GlassEnabled}"
                                              Content="{loc:Loc ThemeGlassOption}" />
                                </Grid>

                                <!-- Glass Backdrop Type -->
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc ThemeBackdropTypeLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeBackdropTypeHint}" />
                                    <ComboBox Grid.Column="1"
                                              Style="{DynamicResource VP.ComboBox}"
                                              SelectedIndex="{Binding GlassBackdropType, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.Items>
                                            <TextBlock Text="{loc:Loc ThemeBackdropNone}" />
                                            <TextBlock Text="Mica" />
                                            <TextBlock Text="Acrylic" />
                                            <TextBlock Text="Tabbed" />
                                        </ComboBox.Items>
                                    </ComboBox>
                                </Grid>

                                <!-- Blur Radius -->
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc ThemeBlurLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeBlurHint}" />
                                    <Slider Grid.Column="1"
                                            Minimum="0" Maximum="60"
                                            Value="{Binding BlurRadius, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding BlurRadius, StringFormat={}{0:F0}}"
                                               Foreground="{DynamicResource VP.TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               FontSize="11" />
                                </Grid>

                                <!-- Glass Opacity -->
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc ThemeOpacityLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeOpacityHint}" />
                                    <Slider Grid.Column="1"
                                            Minimum="0.1" Maximum="1.0"
                                            Value="{Binding GlassOpacity, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding GlassOpacity, StringFormat={}{0:F1}}"
                                               Foreground="{DynamicResource VP.TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               FontSize="11" />
                                </Grid>

                                <!-- Auto Text Contrast -->
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc ThemeAutoContrastLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc ThemeAutoContrastHint}" />
                                    <CheckBox Grid.Column="1"
                                              Style="{DynamicResource VP.CheckBox}"
                                              IsChecked="{Binding AutoTextContrast}"
                                              Content="{loc:Loc ThemeAutoContrastOption}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomScrollSpacer" Height="0" />
                    </StackPanel>
                </ScrollViewer>


                <Button Grid.Column="1"
                        Style="{StaticResource SettingsBackButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"
                        ToolTip="{loc:Loc SettingsBackToAppButton}"
                        Click="BackButton_Click">
                    <TextBlock Text="&#x2715;"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
                <!-- Save Toast -->
                <Border Grid.Column="1" HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{DynamicResource VP.AccentBrush}"
                        CornerRadius="10"
                        Padding="14,8"
                        Margin="0,16,16,0"
                        Visibility="{Binding IsSaveToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding SaveToastMessage}"
                               Foreground="White"
                               FontSize="12" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>





