<UserControl x:Class="SpaceMonger.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:settings="clr-namespace:SpaceMonger.App.Views.SettingsSections"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
             FontFamily="{DynamicResource VP.FontFamily}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SettingsNavButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource VP.SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsBackButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource VP.SurfaceHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource VP.TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource VP.OverlayBrush}" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">
        <!-- Centered card -->
        <Border x:Name="CardBorder" Background="{DynamicResource VP.BackgroundAltBrush}"
                BorderBrush="{DynamicResource VP.BorderLightBrush}"
                BorderThickness="1"
                MaxWidth="720"
                MaxHeight="580"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="124" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="16,46,8,20">
                    <StackPanel>
                        <Button x:Name="ApiNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc AnthropicApiKeyHeader}"
                                Tag="ApiSectionControl"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="GeneralNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc SettingsGeneralNav}"
                                Tag="GeneralSectionControl"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="ThemeNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc ThemeSectionLabel}"
                                Tag="ThemeSectionControl"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="WhitelistNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc SettingsWhitelistNav}"
                                Tag="WhitelistSectionControl"
                                Click="SettingsNavButton_Click" />
                        <Button x:Name="DisclaimerNavButton"
                                Style="{StaticResource SettingsNavButtonStyle}"
                                Content="{loc:Loc SettingsDisclaimerNav}"
                                Tag="DisclaimerSectionControl"
                                Click="SettingsNavButton_Click" />
                    </StackPanel>
                </Grid>
                <!-- Scrollable content -->

                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,56,20,18" ScrollChanged="SettingsScrollViewer_ScrollChanged">
                    <StackPanel x:Name="SettingsContentPanel" SizeChanged="SettingsContentPanel_SizeChanged">

                        <settings:ApiSettingsSection x:Name="ApiSectionControl" />
                        <settings:GeneralSettingsSection x:Name="GeneralSectionControl"
                                                         Margin="0,18,0,0" />
                        <settings:ThemeSettingsSection x:Name="ThemeSectionControl"
                                                       Margin="0,18,0,0" />
                        <settings:WhitelistSettingsSection x:Name="WhitelistSectionControl"
                                                           Margin="0,18,0,0" />
                        <settings:DisclaimerSettingsSection x:Name="DisclaimerSectionControl"
                                                            Margin="0,18,0,0" />
                        <Border x:Name="BottomScrollSpacer" Height="0" />
                    </StackPanel>
                </ScrollViewer>


                <Button Grid.Column="1"
                        Style="{StaticResource SettingsBackButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"
                        ToolTip="{loc:Loc SettingsBackToAppButton}"
                        Click="BackButton_Click">
                    <TextBlock Text="&#x2715;"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
                <!-- Save Toast -->
                <Border Grid.Column="1" HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{DynamicResource VP.AccentBrush}"
                        CornerRadius="10"
                        Padding="14,8"
                        Margin="0,16,16,0"
                        Visibility="{Binding IsSaveToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding SaveToastMessage}"
                               Foreground="White"
                               FontSize="12" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>





