<UserControl x:Class="SpaceMonger.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
             xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
             xmlns:enums="clr-namespace:SpaceMonger.Core.Enums;assembly=SpaceMonger.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}"
             FontFamily="{StaticResource VP.FontFamily}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource VP.TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="120" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        </Style>

        <!-- Back button style: normal → red hover → dark red pressed -->
        <Style x:Key="SettingsBackButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource VP.FontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource VP.SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VP.BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource VP.DangerBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource VP.DangerPressedBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource VP.OverlayBrush}" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">
        <!-- Centered card with solid background -->
        <Border x:Name="CardBorder" Background="{StaticResource VP.BackgroundAltBrush}"
                BorderBrush="{StaticResource VP.BorderLightBrush}"
                BorderThickness="1"
                MaxWidth="640"
                MaxHeight="680"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0"
                CornerRadius="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: title centered -->
                <Border Grid.Row="0" Margin="24,20,24,12">
                    <TextBlock Text="{loc:Loc SettingsTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource VP.TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Back button: upper-right corner, concentric with panel rounded corners -->
                <Button Grid.Row="0"
                        Style="{StaticResource SettingsBackButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"
                        ToolTip="{loc:Loc SettingsBackToAppButton}"
                        Click="BackButton_Click">
                    <TextBlock Text="&#x2715;"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>

                <!-- Scrollable content -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,0,24,24">
                    <StackPanel>
                        <!-- AI & API Section -->
                        <TextBlock Text="{loc:Loc SettingsAiApiSection}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <Border Background="{StaticResource VP.SettingsCardBrush}"
                                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="12" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc AnthropicApiKeyHeader}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsApiKeyEncryptedHint}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Style="{StaticResource VP.TextBox}"
                                                 Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{loc:Loc ApiKeyToolTip}"
                                                 LostFocus="AutoSaveOnLostFocus" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="{loc:Loc ValidateButton}"
                                                    Style="{StaticResource VP.Button}"
                                                    Command="{Binding ValidateCommand}"
                                                    Width="90" Padding="8,5" />
                                            <TextBlock Margin="10,4,0,0"
                                                       Text="{Binding ValidationStatusText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ValidationState}" Value="{x:Static vm:ValidationState.Valid}">
                                                                <Setter Property="Foreground" Value="{StaticResource VP.SuccessBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ValidationState}" Value="{x:Static vm:ValidationState.Invalid}">
                                                                <Setter Property="Foreground" Value="{StaticResource VP.DangerBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ValidationMessage}"
                                                   Foreground="{StaticResource VP.DangerBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc AnthropicBaseUrlHeader}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsBaseUrlExample}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource VP.TextBox}"
                                             Text="{Binding AnthropicBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Models Section -->
                        <TextBlock Text="{loc:Loc SettingsModelsSection}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <Border Background="{StaticResource VP.SettingsCardBrush}"
                                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="12" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsAnalysisModelLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsAnalysisModelHint}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource VP.TextBox}"
                                             Text="{Binding AnalysisModelName, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsChatModelLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsChatModelHint}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource VP.TextBox}"
                                             Text="{Binding ChatModelName, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="AutoSaveOnLostFocus" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsThinkingLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsThinkingHint}" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource VP.CheckBox}"
                                              IsChecked="{Binding EnableThinking}"
                                              VerticalAlignment="Center"
                                              Content="{loc:Loc SettingsAllowThinkingOption}"
                                              Click="AutoSaveOnChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- General Section -->
                        <TextBlock Text="{loc:Loc SettingsGeneralNav}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource VP.TextSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <Border Background="{StaticResource VP.SettingsCardBrush}"
                                BorderBrush="{StaticResource VP.BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="12">
                            <StackPanel>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsLanguageLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsLanguageHint}" />
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource VP.ComboBox}"
                                              ItemsSource="{x:Static vm:SettingsViewModel.LanguageOptions}"
                                              SelectedValue="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Code"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="AutoSaveOnChanged" />
                                </Grid>
                                <Separator Margin="14,0" />
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc SettingsDefaultCleanupModeLabel}"
                                               Style="{StaticResource SettingsLabelStyle}"
                                               ToolTip="{loc:Loc SettingsDefaultCleanupModeHint}" />
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource VP.ComboBox}"
                                              SelectedItem="{Binding SelectedDeletionMode}"
                                              SelectionChanged="AutoSaveOnChanged">
                                        <ComboBox.Items>
                                            <enums:DeletionMode>MoveToRecycleBin</enums:DeletionMode>
                                            <enums:DeletionMode>PermanentDelete</enums:DeletionMode>
                                        </ComboBox.Items>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Save Toast -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{StaticResource VP.AccentBrush}"
                        CornerRadius="10"
                        Padding="14,8"
                        Margin="0,16,16,0"
                        Visibility="{Binding IsSaveToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding SaveToastMessage}"
                               Foreground="White"
                               FontSize="12" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
