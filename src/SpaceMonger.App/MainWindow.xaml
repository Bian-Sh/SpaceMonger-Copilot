<Window x:Class="SpaceMonger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceMonger.App"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:views="clr-namespace:SpaceMonger.App.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="SpaceMonger Next"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <DockPanel LastChildFill="True">

        <!-- Toolbar (top) -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Band="0" BandIndex="0" Header="Navigation">
                <ComboBox x:Name="DriveSelector"
                          Width="350"
                          VerticalAlignment="Center"
                          Margin="4,2"
                          ItemsSource="{Binding DriveList}"
                          Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          ToolTip="Select a drive or folder to scan, or type/paste a path" />
                <Button x:Name="BrowseButton"
                        Content="Browse..."
                        Padding="8,2"
                        Margin="4,2"
                        Command="{Binding BrowseCommand}"
                        ToolTip="Pick a folder to scan" />
                <Separator Margin="4,0" />
                <Button x:Name="ScanButton"
                        Content="Scan"
                        Padding="12,2"
                        Margin="4,2"
                        FontWeight="SemiBold"
                        Command="{Binding ScanCommand}"
                        ToolTip="Start scanning the selected drive or folder" />
                <Button x:Name="CancelScanButton"
                        Content="Cancel"
                        Padding="8,2"
                        Margin="4,2"
                        Command="{Binding CancelScanCommand}"
                        ToolTip="Cancel the current scan" />
                <Button x:Name="AnalyzeButton"
                        Content="Recommend Cleanup"
                        Padding="8,2"
                        Margin="4,2"
                        Click="AnalyzeButton_Click"
                        ToolTip="Uses AI to scan the current view and recommend files and folders that can be safely removed to free up disk space. Only deletable items are shown — files deemed important are not listed." />
                <Separator Margin="4,0" />
                <ToggleButton x:Name="ChatToggleButton"
                              Content="Chat"
                              Padding="8,2"
                              Margin="4,2"
                              ToolTip="Toggle the AI chat panel" />
                <Button x:Name="SettingsButton"
                        Content="&#x2699;"
                        FontSize="16"
                        Padding="6,0"
                        Margin="4,2"
                        Click="SettingsButton_Click"
                        ToolTip="Settings" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar (bottom) -->
        <StatusBar DockPanel.Dock="Bottom" Padding="4,2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Capacity: " FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DriveCapacity}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Used: " FontWeight="SemiBold" />
                    <TextBlock Text="{Binding UsedSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Free: " FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FreeSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Files: " FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Folders: " FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FolderCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ScanProgressText}" FontStyle="Italic" Foreground="#666666" />
            </StatusBarItem>
        </StatusBar>

        <!-- Central content area (fills remaining space) -->
        <Grid x:Name="ContentArea" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Treemap view -->
                <views:TreemapView x:Name="TreemapView" Grid.Row="0" />

                <!-- Recommendations panel (initially collapsed, shown after analysis) -->
                <views:RecommendationsPanel x:Name="RecommendationsPanel"
                                            Grid.Row="1"
                                            Visibility="Collapsed"
                                            MaxHeight="300" />

                <!-- Scanning progress overlay -->
                <Border x:Name="ScanningOverlay"
                        Grid.Row="0" Grid.RowSpan="2"
                        Panel.ZIndex="10"
                        Background="#80000000"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Scanning..."
                                   FontSize="24"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ScanProgressText}"
                                   FontSize="14"
                                   Foreground="#CCCCCC"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chat panel (initially collapsed, shown via toggle button) -->
            <views:ChatPanel x:Name="ChatPanel"
                             Grid.Column="1"
                             Visibility="Collapsed" />
        </Grid>

    </DockPanel>

</Window>
