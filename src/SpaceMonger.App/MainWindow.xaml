<Window x:Class="SpaceMonger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceMonger.App"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:views="clr-namespace:SpaceMonger.App.Views"
        xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{loc:Loc AppTitle}"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="{StaticResource VP.FontFamily}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />  <!-- Title bar -->
            <RowDefinition Height="*" />   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ═══ -->
        <controls:WindowTitleBar x:Name="TitleBar"
                                 Grid.Row="0"
                                 WindowChrome.IsHitTestVisibleInChrome="False" />

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Toolbar -->
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />       <!-- Central content -->
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />    <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ Toolbar (glass) ═══ -->
            <Border Grid.Row="0" Style="{StaticResource VP.GlassPanel}" Padding="8,6">
                <DockPanel LastChildFill="True">
                    <!-- Right: settings -->
                    <Button x:Name="SettingsButton"
                            DockPanel.Dock="Right"
                            Width="36" Height="32"
                            Padding="0"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="SettingsButton_Click"
                            ToolTip="{loc:Loc SettingsButtonToolTip}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="6" Padding="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{StaticResource VP.SurfaceHoverBrush}" />
                                        <Setter Property="Foreground"
                                                Value="{StaticResource VP.TextPrimaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>

                    <!-- Left: navigation buttons -->
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BackButton"
                                Width="32" Height="32"
                                Padding="0"
                                Style="{StaticResource VP.Button}"
                                Click="BackButton_Click"
                                ToolTip="{loc:Loc NavigateBackToolTip}">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="ForwardButton"
                                Width="32" Height="32"
                                Padding="0"
                                Style="{StaticResource VP.Button}"
                                Click="ForwardButton_Click"
                                IsEnabled="False"
                                ToolTip="{loc:Loc NavigateForwardToolTip}">
                            <TextBlock Text="&#xE72A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="UpButton"
                                Width="32" Height="32"
                                Padding="0"
                                Margin="2,0,6,0"
                                Style="{StaticResource VP.Button}"
                                Click="UpButton_Click"
                                IsEnabled="False"
                                ToolTip="{loc:Loc NavigateUpToolTip}">
                            <TextBlock Text="&#xE74A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- Center: address bar + action buttons (fills remaining space) -->
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Editable path / address bar -->
                        <TextBox x:Name="PathTextBox"
                                 Grid.Column="0"
                                 Style="{StaticResource VP.TextBox}"
                                 Text="{Binding SelectedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="PathTextBox_KeyDown"
                                 Margin="0,0,6,0"
                                 ToolTip="{loc:Loc PathSelectorToolTip}" />

                        <Button x:Name="BrowseButton"
                                Grid.Column="1"
                                Content="{loc:Loc BrowseButton}"
                                Style="{StaticResource VP.Button}"
                                Margin="0,0,4,0"
                                Command="{Binding BrowseCommand}"
                                ToolTip="{loc:Loc BrowseButtonToolTip}" />

                        <Rectangle Grid.Column="2" Width="1" Margin="6,4"
                                   Fill="{StaticResource VP.BorderSubtleBrush}" />

                        <Button x:Name="ScanButton"
                                Grid.Column="3"
                                Content="{loc:Loc ScanButton}"
                                Style="{StaticResource VP.AccentButton}"
                                Padding="16,7"
                                Margin="0,0,4,0"
                                Command="{Binding ScanCommand}"
                                ToolTip="{loc:Loc ScanButtonToolTip}" />

                        <Button x:Name="AnalyzeButton"
                                Grid.Column="4"
                                Content="{loc:Loc AnalyzeButton}"
                                Margin="0"
                                VerticalAlignment="Center"
                                ToolTipService.ShowOnDisabled="True"
                                Click="AnalyzeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource VP.AccentButton}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Setter Property="ToolTip" Value="{loc:Loc RecommendCleanupToolTip}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.RecommendationsVM.IsAnalyzing, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="ToolTip" Value="{loc:Loc AnalysisInProgressToolTip}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- ═══ Central Content ═══ -->
            <Grid x:Name="ContentArea" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="420" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="ChatPanelColumn" Width="360" MinWidth="260" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="220" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="RecommendationsPanelRow" Height="340" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <!-- Treemap view -->
                    <views:TreemapView x:Name="TreemapView" Grid.Row="0" />

                    <!-- Subtle splitter -->
                    <GridSplitter x:Name="RecommendationsSplitter"
                                  Grid.Row="1"
                                  Style="{StaticResource VP.GridSplitterH}"
                                  Margin="8,4"
                                  Visibility="Visible" />

                    <!-- Bottom tool window: Chrome-style tabs + content -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Tab bar (outside container border, Chrome-style) -->
                        <Border Grid.Row="0"
                                Background="{StaticResource VP.SurfaceBrush}"
                                CornerRadius="10,10,0,0"
                                Margin="0,0,0,-0.5">
                        <DockPanel>

                            <!-- Console filter (docked right, only visible when console tab is active) -->
                            <Button x:Name="ConsoleFilterButton"
                                    DockPanel.Dock="Right"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Width="28" Height="28"
                                    Padding="0"
                                    Margin="4,0"
                                    Visibility="Collapsed"
                                    ToolTip="{loc:Loc ConsoleFilterToolTip}"
                                    Foreground="{StaticResource VP.TextSecondaryBrush}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="ConsoleFilterButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Padding="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource VP.SurfaceHoverBrush}" />
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource VP.TextPrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE712;"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="ConsoleLevelVerboseMenuItem" Header="Verbose" IsCheckable="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                        <MenuItem x:Name="ConsoleLevelInfoMenuItem" Header="Info" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                        <MenuItem x:Name="ConsoleLevelWarningMenuItem" Header="Warning" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                        <MenuItem x:Name="ConsoleLevelErrorMenuItem" Header="Error" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <!-- Tab buttons (flush left, Chrome-style) -->
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RecommendationsTabBtn"
                                             Content="{loc:Loc RecommendationsTabHeader}"
                                             Style="{StaticResource VP.TabButton}"
                                             IsChecked="True"
                                             Checked="RecommendationsTab_Checked"
                                             GroupName="BottomTabs" />
                                <RadioButton x:Name="ConsoleTabBtn"
                                             Content="{loc:Loc ConsoleTabHeader}"
                                             Style="{StaticResource VP.TabButton}"
                                             Checked="ConsoleTab_Checked"
                                             GroupName="BottomTabs" />
                            </StackPanel>
                        </DockPanel>
                        </Border>

                        <!-- Content area (border connects to active tab) -->
                        <Border Grid.Row="1"
                                Background="{StaticResource VP.SurfaceBrush}"
                                BorderBrush="{StaticResource VP.BorderLightBrush}"
                                BorderThickness="0.5,0,0.5,0.5"
                                CornerRadius="0,0,10,10"
                                Margin="0,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.3"
                                                  Direction="270" />
                            </Border.Effect>
                            <Grid MinHeight="120">
                                <!-- Recommendations panel content -->
                                <views:RecommendationsPanel x:Name="RecommendationsPanel"
                                                            Visibility="Visible" />

                                <!-- Console panel content -->
                                <TextBox x:Name="ConsoleTextBox"
                                         Margin="4,0,4,4"
                                         Padding="12,10"
                                         Background="#1A1B26"
                                         Foreground="#A9DC76"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Code, SF Mono, Menlo, Consolas, monospace"
                                         FontSize="12.5"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         CaretBrush="#A9DC76"
                                         Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Vertical splitter -->
                <GridSplitter Grid.Column="1"
                              Style="{StaticResource VP.GridSplitterV}"
                              Margin="4,0" />

                <!-- Chat panel -->
                <views:ChatPanel x:Name="ChatPanel"
                                 Grid.Column="2"
                                 Visibility="Visible" />
            </Grid>

            <!-- ═══ Status Bar (flat) ═══ -->
            <DockPanel Grid.Row="4" LastChildFill="False" Margin="4,0">
                <DockPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource VP.TextSecondaryBrush}" />
                        <Setter Property="FontSize" Value="11.5" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </DockPanel.Resources>

                <TextBlock>
                    <Run Text="{loc:Loc CapacityLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding DriveCapacity, Mode=OneWay}" />
                </TextBlock>
                <Rectangle Width="1" Height="12" Margin="10,0"
                           Fill="{StaticResource VP.BorderSubtleBrush}"
                           VerticalAlignment="Center" />
                <TextBlock>
                    <Run Text="{loc:Loc UsedLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding UsedSpace, Mode=OneWay}" />
                </TextBlock>
                <Rectangle Width="1" Height="12" Margin="10,0"
                           Fill="{StaticResource VP.BorderSubtleBrush}"
                           VerticalAlignment="Center" />
                <TextBlock>
                    <Run Text="{loc:Loc FreeLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding FreeSpace, Mode=OneWay}" />
                </TextBlock>
                <Rectangle Width="1" Height="12" Margin="10,0"
                           Fill="{StaticResource VP.BorderSubtleBrush}"
                           VerticalAlignment="Center" />
                <TextBlock>
                    <Run Text="{loc:Loc FilesLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding FileCount, Mode=OneWay}" />
                </TextBlock>
                <Rectangle Width="1" Height="12" Margin="10,0"
                           Fill="{StaticResource VP.BorderSubtleBrush}"
                           VerticalAlignment="Center" />
                <TextBlock>
                    <Run Text="{loc:Loc FoldersLabel}" FontWeight="SemiBold" />
                    <Run Text="{Binding FolderCount, Mode=OneWay}" />
                </TextBlock>
                <Rectangle Width="1" Height="12" Margin="10,0"
                           Fill="{StaticResource VP.BorderSubtleBrush}"
                           VerticalAlignment="Center" />
                <TextBlock FontStyle="Italic">
                    <Hyperlink Click="StatusConsoleLink_Click"
                               Foreground="{StaticResource VP.AccentBrush}"
                               ToolTip="{loc:Loc OpenConsoleToolTip}">
                        <Run Text="{Binding ScanProgressText}" />
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
        </Grid>

        <!-- ═══ Settings Page Overlay ═══ -->
        <views:SettingsPage x:Name="SettingsPage"
                            Grid.RowSpan="2"
                            Panel.ZIndex="100"
                            Visibility="Collapsed" />
    </Grid>
</Window>
