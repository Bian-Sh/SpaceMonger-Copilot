<Window x:Class="SpaceMonger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceMonger.App"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:views="clr-namespace:SpaceMonger.App.Views"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{loc:Loc AppTitle}"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid>
    <DockPanel LastChildFill="True">

        <!-- Toolbar (top) -->
        <Grid DockPanel.Dock="Top" Background="#EAF2FB">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" LastChildFill="False" Margin="4,2">
                <TextBlock DockPanel.Dock="Left"
                           Text="{loc:Loc ToolbarNavigation}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <ComboBox x:Name="DriveSelector"
                          DockPanel.Dock="Left"
                          Width="350"
                          VerticalAlignment="Center"
                          Margin="0,0,4,0"
                          ItemsSource="{Binding DriveList}"
                          Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          ToolTip="{loc:Loc PathSelectorToolTip}" />
                <Button x:Name="BrowseButton"
                        DockPanel.Dock="Left"
                        Content="{loc:Loc BrowseButton}"
                        Padding="8,2"
                        Margin="4,0"
                        Command="{Binding BrowseCommand}"
                        ToolTip="{loc:Loc BrowseButtonToolTip}" />
                <Separator DockPanel.Dock="Left" Margin="4,0" />
                <Button x:Name="ScanButton"
                        DockPanel.Dock="Left"
                        Content="{loc:Loc ScanButton}"
                        Width="50"
                        Height="28"
                        Padding="0"
                        Margin="4,0"
                        FontWeight="SemiBold"
                        Command="{Binding ScanCommand}"
                        ToolTip="{loc:Loc ScanButtonToolTip}" />
            </DockPanel>
            <Button x:Name="SettingsButton"
                    Grid.Column="1"
                    Content="&#x2699;"
                    FontSize="17"
                    Width="30"
                    Height="24"
                    Padding="0"
                    Margin="0,4,8,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#333333"
                    Click="SettingsButton_Click"
                    ToolTip="{loc:Loc SettingsButtonToolTip}" />
        </Grid>

        <!-- Status bar (bottom) -->
        <StatusBar DockPanel.Dock="Bottom" Padding="4,2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc CapacityLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DriveCapacity}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc UsedLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding UsedSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FreeLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FreeSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FilesLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FoldersLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FolderCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock FontStyle="Italic">
                    <Hyperlink Click="StatusConsoleLink_Click"
                               ToolTip="{loc:Loc OpenConsoleToolTip}">
                        <Run Text="{Binding ScanProgressText}" />
                    </Hyperlink>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Central content area (fills remaining space) -->
        <Grid x:Name="ContentArea" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="360" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="220" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="RecommendationsPanelRow" Height="260" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Treemap view -->
                <views:TreemapView x:Name="TreemapView" Grid.Row="0" />

                <!-- Resizer between treemap and recommendations -->
                <GridSplitter x:Name="RecommendationsSplitter"
                              Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D0D0D0"
                              ShowsPreview="True"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Visibility="Visible"
                              Cursor="SizeNS" />

                <!-- Bottom tool window: recommendations and console share the same resizable area. -->
                <Grid Grid.Row="2" MinHeight="120">
                    <TabControl x:Name="BottomTabs"
                                Visibility="Visible"
                                SelectionChanged="BottomTabs_SelectionChanged">
                        <TabItem x:Name="RecommendationsTab" Header="{loc:Loc RecommendationsTabHeader}">
                            <views:RecommendationsPanel x:Name="RecommendationsPanel" />
                        </TabItem>
                        <TabItem x:Name="ConsoleTab" Header="{loc:Loc ConsoleTabHeader}">
                            <TextBox x:Name="ConsoleTextBox"
                                     Margin="0"
                                     Padding="8"
                                     Background="#1E1E1E"
                                     Foreground="#DCDCDC"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </TabItem>
                    </TabControl>
                    <DockPanel x:Name="ConsoleToolbarOverlay"
                               Height="24"
                               Margin="86,0,0,0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"
                               LastChildFill="False"
                               Panel.ZIndex="20"
                               Background="Transparent">
                        <Button x:Name="ConsoleFilterButton"
                                DockPanel.Dock="Right"
                                Content="⋮"
                                Width="22"
                                Height="20"
                                Padding="0"
                                Margin="0,2,6,2"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#444444"
                                ToolTip="{loc:Loc ConsoleFilterToolTip}"
                                Click="ConsoleFilterButton_Click">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="ConsoleLevelVerboseMenuItem" Header="Verbose" IsCheckable="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelInfoMenuItem" Header="Info" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelWarningMenuItem" Header="Warning" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelErrorMenuItem" Header="Error" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="ConsoleLogLevel_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </DockPanel>
                </Grid>

            </Grid>

            <!-- Resizer between main workspace and chat panel -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D0D0D0"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- Chat panel is always visible and resizable. -->
            <views:ChatPanel x:Name="ChatPanel"
                             Grid.Column="2"
                             Visibility="Visible" />

        </Grid>

    </DockPanel>

        <views:SettingsPage x:Name="SettingsPage"
                            Panel.ZIndex="100"
                            Visibility="Collapsed" />
    </Grid>

</Window>



