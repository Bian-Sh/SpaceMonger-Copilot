<Window x:Class="SpaceMonger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceMonger.App"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:views="clr-namespace:SpaceMonger.App.Views"
        xmlns:controls="clr-namespace:SpaceMonger.App.Controls"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{loc:Loc AppTitle}"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="{DynamicResource VP.FontFamily}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid" Background="{DynamicResource VP.BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />  <!-- Title bar -->
            <RowDefinition Height="*" />   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- 鈺愨晲鈺?Custom Title Bar 鈺愨晲鈺?-->
        <controls:WindowTitleBar x:Name="TitleBar"
                                 Grid.Row="0"
                                 WindowChrome.IsHitTestVisibleInChrome="True" />

        <!-- 鈺愨晲鈺?Main Content 鈺愨晲鈺?-->
        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Toolbar -->
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />       <!-- Central content -->
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />    <!-- Status bar -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="360" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <!-- 鈺愨晲鈺?Toolbar (aligned with treemap, not chat panel) 鈺愨晲鈺?-->
            <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource VP.GlassPanel}" Padding="8,6">
                <DockPanel LastChildFill="True">

                    <!-- Left: navigation buttons (transparent, hover glow) -->
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BackButton"
                                Width="32" Height="32"
                                Style="{DynamicResource VP.ButtonIcon}"
                                Click="BackButton_Click"
                                ToolTip="{loc:Loc NavigateBackToolTip}">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" />
                        </Button>
                        <Button x:Name="ForwardButton"
                                Width="32" Height="32"
                                Style="{DynamicResource VP.ButtonIcon}"
                                Click="ForwardButton_Click"
                                IsEnabled="False"
                                ToolTip="{loc:Loc NavigateForwardToolTip}">
                            <TextBlock Text="&#xE72A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" />
                        </Button>
                        <Button x:Name="UpButton"
                                Width="32" Height="32"
                                Margin="2,0,6,0"
                                Style="{DynamicResource VP.ButtonIcon}"
                                Click="UpButton_Click"
                                IsEnabled="False"
                                ToolTip="{loc:Loc NavigateUpToolTip}">
                            <TextBlock Text="&#xE74A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" />
                        </Button>
                    </StackPanel>


                    <Button x:Name="ScanButton"
                            DockPanel.Dock="Right"
                            Content="{loc:Loc ScanButton}"
                            Style="{DynamicResource VP.AccentButton}"
                            Padding="16,5"
                            FontSize="12"
                            Margin="0,0,4,0"
                            Command="{Binding ScanCommand}"
                            PreviewMouseLeftButtonDown="ScanButton_PreviewMouseLeftButtonDown"
                            Click="ScanButton_Click"
                            ToolTip="{loc:Loc ScanButtonToolTip}" />

                    <!-- Address bar: LAST child fills remaining space between nav and action buttons -->
                    <Border x:Name="AddressBarBorder"
                            DockPanel.Dock="Left"
                            Background="{DynamicResource VP.SurfaceBrush}"
                            BorderBrush="{DynamicResource VP.BorderLightBrush}"
                            BorderThickness="0.5"
                            CornerRadius="6"
                            Padding="0"
                            Margin="0,0,4,0"
                            MinWidth="120"
                            Height="32"
                            MouseLeftButtonUp="AddressBar_MouseLeftButtonUp">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Breadcrumb display (visible by default) -->
                            <StackPanel x:Name="BreadcrumbBar"
                                        Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="8,5,4,5"
                                        Visibility="Visible" />

                            <!-- Text edit mode (hidden by default) -->
                            <TextBox x:Name="PathEditTextBox"
                                     Grid.Column="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource VP.TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource VP.TextPrimaryBrush}"
                                     BorderThickness="0"
                                     Padding="8,5"
                                     FontSize="13"
                                     FontFamily="{DynamicResource VP.FontFamily}"
                                     KeyDown="PathEditTextBox_KeyDown"
                                     LostFocus="PathEditTextBox_LostFocus"
                                     Visibility="Collapsed"
                                     ToolTip="{loc:Loc PathSelectorToolTip}" />

                            <!-- Folder picker icon inside address bar, right-aligned -->
                            <Button x:Name="BrowseButton"
                                    Grid.Column="1"
                                    Width="32" Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding BrowseCommand}"
                                    ToolTip="{loc:Loc BrowseButtonToolTip}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <TextBlock x:Name="Ico"
                                                       Text="&#xE838;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource VP.TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Ico" Property="Foreground"
                                                        Value="{DynamicResource VP.TextPrimaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Ico" Property="Foreground"
                                                        Value="{DynamicResource VP.AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="220" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="RecommendationsPanelRow" Height="340" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <!-- View mode tab bar (Treemap / TreeView) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource VP.SurfaceBrush}"
                            CornerRadius="10,10,0,0"
                            Margin="0,0,0,-0.5">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="TreemapTabBtn"
                                         Content="{loc:Loc TreemapTabHeader}"
                                         Style="{DynamicResource VP.TabButton}"
                                         IsChecked="True"
                                         Checked="TreemapTab_Checked"
                                         GroupName="ViewModeTabs" />
                            <RadioButton x:Name="TreeViewTabBtn"
                                         Content="{loc:Loc TreeViewTabHeader}"
                                         Style="{DynamicResource VP.TabButton}"
                                         Checked="TreeViewTab_Checked"
                                         GroupName="ViewModeTabs" />
                            <RadioButton x:Name="AboutTabBtn"
                                         Content="{loc:Loc AboutTabHeader}"
                                         Style="{DynamicResource VP.TabButton}"
                                         Checked="AboutTab_Checked"
                                         GroupName="ViewModeTabs" />
                        </StackPanel>
                    </Border>

                    <!-- Treemap view -->
                    <views:TreemapView x:Name="TreemapView" Grid.Row="1" />

                    <!-- TreeView (hidden by default) -->
                    <views:TreeViewControl x:Name="TreeViewControl" Grid.Row="1" Visibility="Collapsed" />

                    <!-- About page (hidden by default) -->
                    <views:AboutPage x:Name="AboutPage" Grid.Row="1" Visibility="Collapsed" />

                    <!-- Subtle splitter -->
                    <GridSplitter x:Name="RecommendationsSplitter"
                                  Grid.Row="2"
                                  Style="{DynamicResource VP.GridSplitterH}"
                                  Margin="8,4"
                                  Visibility="Visible" />

                    <!-- Bottom tool window: Chrome-style tabs + content -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Tab bar (outside container border, Chrome-style) -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource VP.SurfaceBrush}"
                                CornerRadius="10,10,0,0"
                                Margin="0,0,0,-0.5">
                        <DockPanel>

                            <!-- Console filter (docked right, only visible when console tab is active) -->
                            <Button x:Name="ConsoleFilterButton"
                                    DockPanel.Dock="Right"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Width="28" Height="28"
                                    Padding="0"
                                    Margin="4,0"
                                    Visibility="Collapsed"
                                    ToolTip="{loc:Loc ConsoleFilterToolTip}"
                                    Foreground="{DynamicResource VP.TextSecondaryBrush}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="ConsoleFilterButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Padding="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource VP.SurfaceHoverBrush}" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource VP.TextPrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE712;"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="ConsoleLevelVerboseMenuItem" Header="Verbose" IsCheckable="True" StaysOpenOnClick="True" Click="LogLevelFilter_Click" />
                                        <MenuItem x:Name="ConsoleLevelInfoMenuItem" Header="Info" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="LogLevelFilter_Click" />
                                        <MenuItem x:Name="ConsoleLevelWarningMenuItem" Header="Warning" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="LogLevelFilter_Click" />
                                        <MenuItem x:Name="ConsoleLevelErrorMenuItem" Header="Error" IsCheckable="True" IsChecked="True" StaysOpenOnClick="True" Click="LogLevelFilter_Click" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <!-- Tab buttons (flush left, Chrome-style) -->
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RecommendationsTabBtn"
                                             Content="{loc:Loc RecommendationsTabHeader}"
                                             Style="{DynamicResource VP.TabButton}"
                                             IsChecked="True"
                                             Checked="RecommendationsTab_Checked"
                                             GroupName="BottomTabs" />
                                <RadioButton x:Name="ConsoleTabBtn"
                                             Content="{loc:Loc ConsoleTabHeader}"
                                             Style="{DynamicResource VP.TabButton}"
                                             Checked="ConsoleTab_Checked"
                                             GroupName="BottomTabs" />
                            </StackPanel>
                        </DockPanel>
                        </Border>

                        <!-- Content area (border connects to active tab) -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource VP.SurfaceBrush}"
                                BorderBrush="{DynamicResource VP.BorderLightBrush}"
                                BorderThickness="0.5,0,0.5,0.5"
                                CornerRadius="0,0,10,10"
                                Margin="0,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.3"
                                                  Direction="270" />
                            </Border.Effect>
                            <Grid MinHeight="120">
                                <!-- Recommendations panel content -->
                                <views:RecommendationsPanel x:Name="RecommendationsPanel"
                                                            Visibility="Visible" />

                                <!-- Console panel content -->
                                <Border x:Name="ConsoleFrame"
                                        Margin="4,0,4,4"
                                        Background="#1A1B26"
                                        CornerRadius="0,0,10,10"
                                        ClipToBounds="True"
                                        Visibility="Collapsed">
                                    <ScrollViewer x:Name="ConsoleScrollViewer"
                                                  Padding="12,10"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ConsoleItemsControl"
                                                      FontFamily="Cascadia Code, SF Mono, Menlo, Consolas, monospace"
                                                      FontSize="12.5">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <Run Text="{Binding TimeText, Mode=OneWay}" Foreground="{Binding TimeBrush, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding LevelText, Mode=OneWay}" Foreground="{Binding LevelBrush, Mode=OneWay}" FontWeight="SemiBold" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding DisplayMessage, Mode=OneWay}" Foreground="{Binding MessageBrush, Mode=OneWay}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Chat panel area -->
                <GridSplitter x:Name="ChatSplitter"
                              Grid.RowSpan="3"
                              Grid.Column="1"
                              Style="{DynamicResource VP.GridSplitterV}"
                              Width="12"
                              Margin="0"
                              Background="Transparent">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="{x:Type GridSplitter}">
                            <Grid Background="{TemplateBinding Background}">
                                <Border Width="2"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource VP.BorderSubtleBrush}" />
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <Grid x:Name="ChatPanelViewport"
                      Grid.RowSpan="3"
                      Grid.Column="2"
                      ClipToBounds="True"
                      SizeChanged="ChatPanelViewport_SizeChanged">
                    <Border x:Name="ChatPanelContainer"
                            HorizontalAlignment="Stretch">
                        <views:ChatPanel x:Name="ChatPanel"
                                         Visibility="Visible" />
                    </Border>
                </Grid>

            <Grid Grid.Row="4" Grid.ColumnSpan="3" Margin="4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：磁盘信息 -->
                <DockPanel Grid.Column="0" LastChildFill="False">
                    <DockPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
                            <Setter Property="FontSize" Value="11.5" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DockPanel.Resources>

                    <TextBlock>
                        <Run Text="{loc:Loc CapacityLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding DriveCapacity, Mode=OneWay}" />
                    </TextBlock>
                    <Rectangle Width="1" Height="12" Margin="10,0"
                               Fill="{DynamicResource VP.BorderSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="{loc:Loc UsedLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding UsedSpace, Mode=OneWay}" />
                    </TextBlock>
                    <Rectangle Width="1" Height="12" Margin="10,0"
                               Fill="{DynamicResource VP.BorderSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="{loc:Loc FreeLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding FreeSpace, Mode=OneWay}" />
                    </TextBlock>
                    <Rectangle Width="1" Height="12" Margin="10,0"
                               Fill="{DynamicResource VP.BorderSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="{loc:Loc FilesLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding FileCount, Mode=OneWay}" />
                    </TextBlock>
                    <Rectangle Width="1" Height="12" Margin="10,0"
                               Fill="{DynamicResource VP.BorderSubtleBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="{loc:Loc FoldersLabel}" FontWeight="SemiBold" />
                        <Run Text="{Binding FolderCount, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>

                <!-- 右侧：版本号 -->
                <TextBlock x:Name="VersionDisplay"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           FontSize="14"
                           Margin="0,0,4,0"
                           Cursor="Hand"
                           ToolTip="{loc:Loc VersionDisplayToolTip}"
                           MouseLeftButtonDown="VersionDisplay_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="{DynamicResource VP.TextSecondaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UpdateVM.UpdateAvailable}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource VP.SuccessBrush}" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource VP.AccentBrush}" />
                                    <Setter Property="TextDecorations" Value="Underline" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding UpdateVM.StatusText, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Settings Page Overlay -->
        <views:SettingsPage x:Name="SettingsPage"
                            Grid.RowSpan="2"
                            Panel.ZIndex="100"
                            Visibility="Collapsed" />

        <!-- App Modal Overlay -->
        <controls:AppModalHost x:Name="ModalHost"
                               Grid.RowSpan="2"
                               Panel.ZIndex="200" />
    </Grid>
</Window>

