<Window x:Class="SpaceMonger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceMonger.App"
        xmlns:vm="clr-namespace:SpaceMonger.App.ViewModels"
        xmlns:views="clr-namespace:SpaceMonger.App.Views"
        xmlns:loc="clr-namespace:SpaceMonger.App.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{loc:Loc AppTitle}"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <DockPanel LastChildFill="True">

        <!-- Toolbar (top) -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Band="0" BandIndex="0" Header="{loc:Loc ToolbarNavigation}">
                <ComboBox x:Name="DriveSelector"
                          Width="350"
                          VerticalAlignment="Center"
                          Margin="4,2"
                          ItemsSource="{Binding DriveList}"
                          Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          ToolTip="{loc:Loc PathSelectorToolTip}" />
                <Button x:Name="BrowseButton"
                        Content="{loc:Loc BrowseButton}"
                        Padding="8,2"
                        Margin="4,2"
                        Command="{Binding BrowseCommand}"
                        ToolTip="{loc:Loc BrowseButtonToolTip}" />
                <Separator Margin="4,0" />
                <Button x:Name="ScanButton"
                        Content="{loc:Loc ScanButton}"
                        Padding="12,2"
                        Margin="4,2"
                        FontWeight="SemiBold"
                        Command="{Binding ScanCommand}"
                        ToolTip="{loc:Loc ScanButtonToolTip}" />
                <Button x:Name="CancelScanButton"
                        Content="{loc:Loc CancelButton}"
                        Padding="8,2"
                        Margin="4,2"
                        Command="{Binding CancelScanCommand}"
                        ToolTip="{loc:Loc CancelScanToolTip}" />
                <Button x:Name="AnalyzeButton"
                        Content="{loc:Loc RecommendCleanupButton}"
                        Padding="8,2"
                        Margin="4,2"
                        Click="AnalyzeButton_Click"
                        ToolTip="{loc:Loc RecommendCleanupToolTip}" />
                <Separator Margin="4,0" />
                <Button x:Name="SettingsButton"
                        Content="&#x2699;"
                        FontSize="16"
                        Padding="6,0"
                        Margin="4,2"
                        Click="SettingsButton_Click"
                        ToolTip="{loc:Loc SettingsButtonToolTip}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar (bottom) -->
        <StatusBar DockPanel.Dock="Bottom" Padding="4,2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc CapacityLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DriveCapacity}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc UsedLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding UsedSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FreeLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FreeSpace}" MinWidth="80" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FilesLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc FoldersLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FolderCount}" MinWidth="60" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock FontStyle="Italic">
                    <Hyperlink Click="StatusConsoleLink_Click"
                               ToolTip="打开控制台">
                        <Run Text="{Binding ScanProgressText}" />
                    </Hyperlink>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Central content area (fills remaining space) -->
        <Grid x:Name="ContentArea" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="ChatPanelColumn" Width="360" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="220" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="RecommendationsPanelRow" Height="260" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Treemap view -->
                <views:TreemapView x:Name="TreemapView" Grid.Row="0" />

                <!-- Resizer between treemap and recommendations -->
                <GridSplitter x:Name="RecommendationsSplitter"
                              Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D0D0D0"
                              ShowsPreview="True"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Visibility="Visible"
                              Cursor="SizeNS" />

                <!-- Bottom tool window: recommendations and console share the same resizable area. -->
                <TabControl x:Name="BottomTabs"
                            Grid.Row="2"
                            MinHeight="120"
                            Visibility="Visible">
                    <TabItem x:Name="RecommendationsTab" Header="推荐清理">
                        <views:RecommendationsPanel x:Name="RecommendationsPanel" />
                    </TabItem>
                    <TabItem x:Name="ConsoleTab" Header="控制台">
                        <DockPanel Background="#1E1E1E">
                            <Menu DockPanel.Dock="Top"
                                  HorizontalAlignment="Right"
                                  Background="#2D2D30"
                                  Foreground="#DCDCDC">
                                <MenuItem Header="Log Level">
                                    <MenuItem x:Name="ConsoleLevelVerboseMenuItem" Header="Verbose" IsCheckable="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelInfoMenuItem" Header="Info" IsCheckable="True" IsChecked="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelWarningMenuItem" Header="Warning" IsCheckable="True" Click="ConsoleLogLevel_Click" />
                                    <MenuItem x:Name="ConsoleLevelErrorMenuItem" Header="Error" IsCheckable="True" Click="ConsoleLogLevel_Click" />
                                </MenuItem>
                            </Menu>
                            <TextBox x:Name="ConsoleTextBox"
                                     Margin="0"
                                     Padding="8"
                                     Background="#1E1E1E"
                                     Foreground="#DCDCDC"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </DockPanel>
                    </TabItem>
                </TabControl>

                <!-- Scanning progress overlay -->
                <Border x:Name="ScanningOverlay"
                        Grid.Row="0" Grid.RowSpan="3"
                        Panel.ZIndex="10"
                        Background="#80000000"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Loc AnalyzingScanResultsStatus}"
                                   FontSize="24"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ScanProgressText}"
                                   FontSize="14"
                                   Foreground="#CCCCCC"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Resizer between main workspace and chat panel -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D0D0D0"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- Chat panel is always visible and resizable. -->
            <views:ChatPanel x:Name="ChatPanel"
                             Grid.Column="2"
                             Visibility="Visible" />
        </Grid>

    </DockPanel>

</Window>


